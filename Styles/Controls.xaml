<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pill button — squared-rounded -->
    <Style x:Key="PillButtonStyle" TargetType="Button">
        <Setter Property="Background"   Value="{ThemeResource CardBrush}"/>
        <Setter Property="Foreground"   Value="{ThemeResource MutedBrush}"/>
        <Setter Property="BorderBrush"  Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="6"/>
        <Setter Property="Padding"      Value="12,5"/>
        <Setter Property="FontSize"     Value="12"/>
    </Style>

    <!-- Active pill -->
    <Style x:Key="PillButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
        <Setter Property="Background"  Value="#A78BFA"/>
        <Setter Property="Foreground"  Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#A78BFA"/>
    </Style>

    <!-- Icon button -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{ThemeResource MutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="6"/>
        <Setter Property="Width"           Value="32"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="CornerRadius"    Value="6"/>
    </Style>

    <!-- Nav item style — full ControlTemplate so we can render an active-state
         left accent bar, matching Spotify/Notion/Discord conventions. -->
    <Style x:Key="NavItemStyle" TargetType="Button">
        <Setter Property="Background"              Value="Transparent"/>
        <Setter Property="Foreground"              Value="{ThemeResource TextBrush}"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="HorizontalAlignment"     Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding"                 Value="10,5"/>
        <Setter Property="MinHeight"               Value="30"/>
        <Setter Property="CornerRadius"            Value="6"/>
        <Setter Property="FontSize"                Value="12"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <!-- Active-state accent bar: rendered when Tag="active" via VSM -->
                        <Border x:Name="AccentBar" Grid.Column="0"
                                Width="3" Margin="0,4"
                                CornerRadius="2"
                                Background="Transparent"/>
                        <Border x:Name="RootBg" Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Left"
                                              VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootBg.Background" Value="{ThemeResource NavHoverBgBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootBg.Background" Value="{ThemeResource NavPressedBgBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Active variant — purple accent bar + tinted bg + bold -->
    <Style x:Key="NavItemActiveStyle" TargetType="Button">
        <Setter Property="Background"              Value="{ThemeResource NavActiveBgBrush}"/>
        <Setter Property="Foreground"              Value="{ThemeResource TextBrush}"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="HorizontalAlignment"     Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding"                 Value="10,5"/>
        <Setter Property="MinHeight"               Value="30"/>
        <Setter Property="CornerRadius"            Value="6"/>
        <Setter Property="FontSize"                Value="12"/>
        <Setter Property="FontWeight"              Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="3"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" Width="3" Margin="0,4"
                                CornerRadius="2"
                                Background="{StaticResource BrandPurpleBrush}"/>
                        <Border x:Name="RootBg" Grid.Column="1"
                                Background="{TemplateBinding Background}"
                                CornerRadius="{TemplateBinding CornerRadius}"
                                Padding="{TemplateBinding Padding}">
                            <ContentPresenter HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Left"
                                              VerticalAlignment="Center"
                                              Foreground="{TemplateBinding Foreground}"/>
                        </Border>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootBg.Background" Value="{ThemeResource NavActiveHoverBgBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Sidebar section micro-label — uppercase, muted, small -->
    <Style x:Key="SidebarGroupLabelStyle" TargetType="TextBlock">
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Foreground"      Value="{ThemeResource MutedBrush}"/>
        <Setter Property="CharacterSpacing" Value="150"/>
        <Setter Property="Margin"          Value="14,12,10,4"/>
        <Setter Property="Opacity"         Value="0.65"/>
    </Style>

    <!-- Badge -->
    <Style x:Key="BadgeStyle" TargetType="Border">
        <Setter Property="Background"    Value="{ThemeResource ChipBrush}"/>
        <Setter Property="CornerRadius"  Value="10"/>
        <Setter Property="Padding"       Value="6,2"/>
        <Setter Property="MinWidth"      Value="22"/>
    </Style>

    <!-- Status dot -->
    <Style x:Key="OnlineDotStyle" TargetType="Ellipse">
        <Setter Property="Width"             Value="8"/>
        <Setter Property="Height"            Value="8"/>
        <Setter Property="Fill"              Value="#22C55E"/>
        <Setter Property="Margin"            Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="OfflineDotStyle" TargetType="Ellipse">
        <Setter Property="Width"             Value="8"/>
        <Setter Property="Height"            Value="8"/>
        <Setter Property="Fill"              Value="#6B7280"/>
        <Setter Property="Margin"            Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Sidebar section header (LIBRARIES / TOP GENRES / COLLECTIONS).
         Compact orange-tinted card with a thin amber border and a slightly
         darker hover state. Replaces the bulky Expander chrome. -->
    <Style x:Key="SidebarSectionHeaderStyle" TargetType="Button">
        <Setter Property="Background"      Value="{ThemeResource SectionHeaderBgBrush}"/>
        <Setter Property="BorderBrush"     Value="{ThemeResource SectionHeaderBorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="Foreground"      Value="{ThemeResource SectionHeaderTextBrush}"/>
        <Setter Property="HorizontalAlignment"        Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding"         Value="10,4,8,4"/>
        <Setter Property="MinHeight"       Value="0"/>
        <Setter Property="CornerRadius"    Value="6"/>
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="RootBorder"
                            Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}"
                            BorderThickness="{TemplateBinding BorderThickness}"
                            CornerRadius="{TemplateBinding CornerRadius}"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalContentAlignment="{TemplateBinding HorizontalContentAlignment}"
                                          VerticalContentAlignment="Center"
                                          Content="{TemplateBinding Content}"/>
                        <VisualStateManager.VisualStateGroups>
                            <VisualStateGroup x:Name="CommonStates">
                                <VisualState x:Name="Normal"/>
                                <VisualState x:Name="PointerOver">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Background" Value="{ThemeResource SectionHeaderHoverBgBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Pressed">
                                    <VisualState.Setters>
                                        <Setter Target="RootBorder.Background" Value="{ThemeResource SectionHeaderHoverBgBrush}"/>
                                    </VisualState.Setters>
                                </VisualState>
                                <VisualState x:Name="Disabled"/>
                            </VisualStateGroup>
                        </VisualStateManager.VisualStateGroups>
                    </Border>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Section title -->
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Foreground"      Value="{ThemeResource MutedBrush}"/>
        <Setter Property="Margin"          Value="12,16,12,4"/>
        <Setter Property="CharacterSpacing" Value="100"/>
    </Style>

    <!-- Movie card poster badge -->
    <Style x:Key="PosterBadgeStyle" TargetType="Border">
        <Setter Property="Background"   Value="#CC000000"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding"      Value="4,2"/>
    </Style>

    <!-- Statistics tile (small square card with a big number) -->
    <Style x:Key="StatTileStyle" TargetType="Border">
        <Setter Property="Background"      Value="{ThemeResource CardBrush}"/>
        <Setter Property="BorderBrush"     Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="10"/>
        <Setter Property="Padding"         Value="16"/>
    </Style>

    <!-- Statistics panel (larger container for a chart/list) -->
    <Style x:Key="StatPanelStyle" TargetType="Border">
        <Setter Property="Background"      Value="{ThemeResource CardBrush}"/>
        <Setter Property="BorderBrush"     Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius"    Value="10"/>
        <Setter Property="Padding"         Value="18"/>
    </Style>

</ResourceDictionary>
