<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Pill button -->
    <Style x:Key="PillButtonStyle" TargetType="Button">
        <Setter Property="Background"   Value="{ThemeResource CardBrush}"/>
        <Setter Property="Foreground"   Value="{ThemeResource MutedBrush}"/>
        <Setter Property="BorderBrush"  Value="{ThemeResource BorderBrush}"/>
        <Setter Property="BorderThickness" Value="1"/>
        <Setter Property="CornerRadius" Value="20"/>
        <Setter Property="Padding"      Value="14,6"/>
        <Setter Property="FontSize"     Value="12"/>
    </Style>

    <!-- Active pill -->
    <Style x:Key="PillButtonActiveStyle" TargetType="Button" BasedOn="{StaticResource PillButtonStyle}">
        <Setter Property="Background"  Value="#A78BFA"/>
        <Setter Property="Foreground"  Value="#FFFFFF"/>
        <Setter Property="BorderBrush" Value="#A78BFA"/>
    </Style>

    <!-- Icon button -->
    <Style x:Key="IconButtonStyle" TargetType="Button">
        <Setter Property="Background"      Value="Transparent"/>
        <Setter Property="Foreground"      Value="{ThemeResource MutedBrush}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="Padding"         Value="6"/>
        <Setter Property="Width"           Value="32"/>
        <Setter Property="Height"          Value="32"/>
        <Setter Property="CornerRadius"    Value="6"/>
    </Style>

    <!-- Nav item style -->
    <Style x:Key="NavItemStyle" TargetType="Button">
        <Setter Property="Background"              Value="Transparent"/>
        <Setter Property="Foreground"              Value="{ThemeResource TextBrush}"/>
        <Setter Property="BorderThickness"         Value="0"/>
        <Setter Property="HorizontalAlignment"     Value="Stretch"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="Padding"                 Value="12,8"/>
        <Setter Property="CornerRadius"            Value="8"/>
        <Setter Property="FontSize"                Value="13"/>
    </Style>

    <!-- Badge -->
    <Style x:Key="BadgeStyle" TargetType="Border">
        <Setter Property="Background"    Value="{ThemeResource ChipBrush}"/>
        <Setter Property="CornerRadius"  Value="10"/>
        <Setter Property="Padding"       Value="6,2"/>
        <Setter Property="MinWidth"      Value="22"/>
    </Style>

    <!-- Status dot -->
    <Style x:Key="OnlineDotStyle" TargetType="Ellipse">
        <Setter Property="Width"             Value="8"/>
        <Setter Property="Height"            Value="8"/>
        <Setter Property="Fill"              Value="#22C55E"/>
        <Setter Property="Margin"            Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <Style x:Key="OfflineDotStyle" TargetType="Ellipse">
        <Setter Property="Width"             Value="8"/>
        <Setter Property="Height"            Value="8"/>
        <Setter Property="Fill"              Value="#6B7280"/>
        <Setter Property="Margin"            Value="0,0,6,0"/>
        <Setter Property="VerticalAlignment" Value="Center"/>
    </Style>

    <!-- Section title -->
    <Style x:Key="SectionTitleStyle" TargetType="TextBlock">
        <Setter Property="FontSize"        Value="10"/>
        <Setter Property="FontWeight"      Value="SemiBold"/>
        <Setter Property="Foreground"      Value="{ThemeResource MutedBrush}"/>
        <Setter Property="Margin"          Value="12,16,12,4"/>
        <Setter Property="CharacterSpacing" Value="100"/>
    </Style>

    <!-- Movie card poster badge -->
    <Style x:Key="PosterBadgeStyle" TargetType="Border">
        <Setter Property="Background"   Value="#CC000000"/>
        <Setter Property="CornerRadius" Value="4"/>
        <Setter Property="Padding"      Value="4,2"/>
    </Style>

</ResourceDictionary>
