<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- ═══ THEME-AWARE SURFACE COLOURS ═══════════════════════════════════ -->
    <ResourceDictionary.ThemeDictionaries>

        <ResourceDictionary x:Key="Dark">
            <SolidColorBrush x:Key="BgBrush"         Color="#0A0A0C"/>
            <SolidColorBrush x:Key="SidebarBrush"    Color="#0F0F18"/>
            <SolidColorBrush x:Key="CardBrush"       Color="#14141F"/>
            <SolidColorBrush x:Key="CardHoverBrush"  Color="#1E1E2E"/>
            <SolidColorBrush x:Key="BorderBrush"     Color="#2A2A3A"/>
            <SolidColorBrush x:Key="TextBrush"       Color="#E8E8F0"/>
            <SolidColorBrush x:Key="MutedBrush"      Color="#6B7280"/>
            <SolidColorBrush x:Key="InputBgBrush"    Color="#14141F"/>
            <SolidColorBrush x:Key="InputBorderBrush" Color="#2A2A3A"/>
            <SolidColorBrush x:Key="ChipBrush"       Color="#1E1E2E"/>
            <SolidColorBrush x:Key="HeroBgBrush"     Color="#990A0A1C"/>
            <SolidColorBrush x:Key="OverlayBrush"    Color="#CC0A0A1C"/>
            <SolidColorBrush x:Key="PlaceholderBgBrush" Color="#1A1A2E"/>
            <SolidColorBrush x:Key="ToastBgBrush"    Color="#1E1E3A"/>
            <SolidColorBrush x:Key="SubtleBgBrush"   Color="#0A1A2A"/>
            <!-- Sidebar section header (orange-tinted) -->
            <SolidColorBrush x:Key="SectionHeaderBgBrush"      Color="#3A2410"/>
            <SolidColorBrush x:Key="SectionHeaderBorderBrush"  Color="#B45309"/>
            <SolidColorBrush x:Key="SectionHeaderHoverBgBrush" Color="#4F2F15"/>
            <SolidColorBrush x:Key="SectionHeaderTextBrush"    Color="#FBBF77"/>
            <!-- Nav item active / hover states (Dark) -->
            <SolidColorBrush x:Key="NavHoverBgBrush"            Color="#1E1E2E"/>
            <SolidColorBrush x:Key="NavPressedBgBrush"          Color="#252538"/>
            <SolidColorBrush x:Key="NavActiveBgBrush"           Color="#33A78BFA"/>
            <SolidColorBrush x:Key="NavActiveHoverBgBrush"      Color="#44A78BFA"/>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Light">
            <SolidColorBrush x:Key="BgBrush"         Color="#F4F4F8"/>
            <SolidColorBrush x:Key="SidebarBrush"    Color="#EAEAF2"/>
            <SolidColorBrush x:Key="CardBrush"       Color="#FFFFFF"/>
            <SolidColorBrush x:Key="CardHoverBrush"  Color="#EBEBFF"/>
            <SolidColorBrush x:Key="BorderBrush"     Color="#D0D0E4"/>
            <SolidColorBrush x:Key="TextBrush"       Color="#1A1A2A"/>
            <SolidColorBrush x:Key="MutedBrush"      Color="#6B7280"/>
            <SolidColorBrush x:Key="InputBgBrush"    Color="#FFFFFF"/>
            <SolidColorBrush x:Key="InputBorderBrush" Color="#C8C8DC"/>
            <SolidColorBrush x:Key="ChipBrush"       Color="#E8E8F4"/>
            <SolidColorBrush x:Key="HeroBgBrush"     Color="#99F0F0FF"/>
            <SolidColorBrush x:Key="OverlayBrush"    Color="#CCF0F0FF"/>
            <SolidColorBrush x:Key="PlaceholderBgBrush" Color="#EEEEFF"/>
            <SolidColorBrush x:Key="ToastBgBrush"    Color="#E8E8FF"/>
            <SolidColorBrush x:Key="SubtleBgBrush"   Color="#E8F0FF"/>
            <!-- Sidebar section header (orange-tinted) -->
            <SolidColorBrush x:Key="SectionHeaderBgBrush"      Color="#FFF4E6"/>
            <SolidColorBrush x:Key="SectionHeaderBorderBrush"  Color="#F59E0B"/>
            <SolidColorBrush x:Key="SectionHeaderHoverBgBrush" Color="#FFE8CC"/>
            <SolidColorBrush x:Key="SectionHeaderTextBrush"    Color="#9A6300"/>
            <!-- Nav item active / hover states (Light) -->
            <SolidColorBrush x:Key="NavHoverBgBrush"            Color="#E0E0EF"/>
            <SolidColorBrush x:Key="NavPressedBgBrush"          Color="#D4D4E8"/>
            <SolidColorBrush x:Key="NavActiveBgBrush"           Color="#22A78BFA"/>
            <SolidColorBrush x:Key="NavActiveHoverBgBrush"      Color="#33A78BFA"/>
        </ResourceDictionary>

        <ResourceDictionary x:Key="Default">
            <!-- Follows the system theme — reuse Dark values as fallback -->
            <SolidColorBrush x:Key="BgBrush"         Color="#0A0A0C"/>
            <SolidColorBrush x:Key="SidebarBrush"    Color="#0F0F18"/>
            <SolidColorBrush x:Key="CardBrush"       Color="#14141F"/>
            <SolidColorBrush x:Key="CardHoverBrush"  Color="#1E1E2E"/>
            <SolidColorBrush x:Key="BorderBrush"     Color="#2A2A3A"/>
            <SolidColorBrush x:Key="TextBrush"       Color="#E8E8F0"/>
            <SolidColorBrush x:Key="MutedBrush"      Color="#6B7280"/>
            <SolidColorBrush x:Key="InputBgBrush"    Color="#14141F"/>
            <SolidColorBrush x:Key="InputBorderBrush" Color="#2A2A3A"/>
            <SolidColorBrush x:Key="ChipBrush"       Color="#1E1E2E"/>
            <SolidColorBrush x:Key="HeroBgBrush"     Color="#990A0A1C"/>
            <SolidColorBrush x:Key="OverlayBrush"    Color="#CC0A0A1C"/>
            <SolidColorBrush x:Key="PlaceholderBgBrush" Color="#1A1A2E"/>
            <SolidColorBrush x:Key="ToastBgBrush"    Color="#1E1E3A"/>
            <SolidColorBrush x:Key="SubtleBgBrush"   Color="#0A1A2A"/>
            <!-- Sidebar section header (orange-tinted) -->
            <SolidColorBrush x:Key="SectionHeaderBgBrush"      Color="#3A2410"/>
            <SolidColorBrush x:Key="SectionHeaderBorderBrush"  Color="#B45309"/>
            <SolidColorBrush x:Key="SectionHeaderHoverBgBrush" Color="#4F2F15"/>
            <SolidColorBrush x:Key="SectionHeaderTextBrush"    Color="#FBBF77"/>
            <!-- Nav item active / hover states (Default = Dark fallback) -->
            <SolidColorBrush x:Key="NavHoverBgBrush"            Color="#1E1E2E"/>
            <SolidColorBrush x:Key="NavPressedBgBrush"          Color="#252538"/>
            <SolidColorBrush x:Key="NavActiveBgBrush"           Color="#33A78BFA"/>
            <SolidColorBrush x:Key="NavActiveHoverBgBrush"      Color="#44A78BFA"/>
        </ResourceDictionary>

    </ResourceDictionary.ThemeDictionaries>

    <!-- ═══ BRAND COLOURS (fixed — same in all themes) ════════════════════ -->
    <SolidColorBrush x:Key="BrandPurpleBrush" Color="#A78BFA"/>
    <SolidColorBrush x:Key="BrandGoldBrush"   Color="#F59E0B"/>
    <SolidColorBrush x:Key="AccentRedBrush"   Color="#EF4444"/>
    <SolidColorBrush x:Key="AccentGreenBrush" Color="#22C55E"/>

</ResourceDictionary>
