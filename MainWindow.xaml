<Window
    x:Class="CineLibraryCS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS"
    xmlns:models="using:CineLibraryCS.Models"
    xmlns:views="using:CineLibraryCS.Views"
    Title="CineLibrary">

    <Grid x:Name="RootGrid" Background="{ThemeResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ CUSTOM TITLEBAR (drag region) ═══ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center" Margin="12,0,0,0">
                <TextBlock Text="🎬" FontSize="14" VerticalAlignment="Center"/>
                <TextBlock Text="CineLibrary" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <!-- ═══ MAIN CONTENT ROW ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <Grid x:Name="SidebarGrid" Grid.Column="0" Background="{ThemeResource SidebarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo -->
                <Button Grid.Row="0" Click="OnAboutClick"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="16,16,16,12">
                    <StackPanel x:Name="LogoPanel" Orientation="Horizontal" Spacing="12">
                        <Border Background="#A78BFA" CornerRadius="10" Width="40" Height="40">
                            <TextBlock Text="🎬" FontSize="20" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <StackPanel x:Name="LogoTextPanel" VerticalAlignment="Center">
                            <TextBlock Text="CINELIBRARY" FontSize="14" FontWeight="Bold"
                                       Foreground="{ThemeResource TextBrush}" CharacterSpacing="150"/>
                            <TextBlock Text="Movie Catalog" FontSize="11" Foreground="{ThemeResource MutedBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Nav -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NavPanel" Padding="8,0">

                        <!-- All Movies -->
                        <Button x:Name="BtnAllMovies" Style="{StaticResource NavItemStyle}"
                                Click="OnNavAllMovies">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="🎬" VerticalAlignment="Center"/>
                                    <TextBlock Text="All Movies" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="TotalBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Favorites -->
                        <Button Style="{StaticResource NavItemStyle}" Click="OnNavFavorites">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="⭐" VerticalAlignment="Center"/>
                                <TextBlock Text="Favorites" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Watchlist (v1.3) -->
                        <Button x:Name="BtnWatchlist" Style="{StaticResource NavItemStyle}" Click="OnNavWatchlist">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="📋" VerticalAlignment="Center"/>
                                    <TextBlock Text="To Watch" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="WatchlistBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Continue Watching (v1.8) -->
                        <Button x:Name="BtnContinueWatching" Style="{StaticResource NavItemStyle}"
                                Click="OnNavContinueWatching">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="▶" VerticalAlignment="Center"/>
                                    <TextBlock Text="Continue Watching" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="ContinueWatchingBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Recently Added (v1.7) -->
                        <Button Style="{StaticResource NavItemStyle}" Click="OnNavRecentlyAdded">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🆕" VerticalAlignment="Center"/>
                                <TextBlock Text="Recently Added" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Random Pick (v1.7) -->
                        <Button Style="{StaticResource NavItemStyle}" Click="OnNavRandomPick">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="🎲" VerticalAlignment="Center"/>
                                <TextBlock Text="Surprise me" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Statistics (v1.4.1) -->
                        <Button x:Name="BtnStatistics" Style="{StaticResource NavItemStyle}" Click="OnNavStatistics">
                            <StackPanel Orientation="Horizontal" Spacing="8">
                                <TextBlock Text="📊" VerticalAlignment="Center"/>
                                <TextBlock Text="Statistics" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Drives -->
                        <Button Style="{StaticResource NavItemStyle}" Click="OnNavDrives">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="8">
                                    <TextBlock Text="💾" VerticalAlignment="Center"/>
                                    <TextBlock Text="Drives" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="DrivesBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Libraries section (collapsible, custom header) -->
                        <StackPanel x:Name="LibrariesHeader" Visibility="Collapsed" Margin="0,8,0,0">
                            <Button Tag="Libraries" Click="OnSidebarSectionToggle"
                                    Style="{StaticResource SidebarSectionHeaderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LIBRARIES" CharacterSpacing="100"/>
                                    <TextBlock x:Name="LibrariesChevron" Grid.Column="1"
                                               Text="⌃" FontSize="12"/>
                                </Grid>
                            </Button>
                            <ItemsRepeater x:Name="DrivesRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveInfo">
                                        <Button Style="{StaticResource NavItemStyle}"
                                                Tag="{Binding VolumeSerial}"
                                                Click="OnNavDriveItem">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                                         Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Style="{StaticResource BadgeStyle}">
                                                    <TextBlock Text="{Binding MovieCount}" FontSize="11"
                                                               Foreground="{ThemeResource MutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- Top Genres section (collapsible) — order: Libraries → Top Genres → Collections. -->
                        <StackPanel x:Name="GenresHeader" Visibility="Collapsed" Margin="0,4,0,0">
                            <Button Tag="Genres" Click="OnSidebarSectionToggle"
                                    Style="{StaticResource SidebarSectionHeaderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="TOP GENRES" CharacterSpacing="100"/>
                                    <TextBlock x:Name="GenresChevron" Grid.Column="1"
                                               Text="⌃" FontSize="12"/>
                                </Grid>
                            </Button>
                            <ItemsRepeater x:Name="GenresRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:GenreFacet">
                                        <Button Style="{StaticResource NavItemStyle}"
                                                Tag="{Binding Name}"
                                                Click="OnNavGenre">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="🏷" VerticalAlignment="Center"
                                                               Foreground="{ThemeResource MutedBrush}"/>
                                                    <TextBlock Text="{Binding Name}" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                                    <TextBlock Text="{Binding Count}" FontSize="11"
                                                               Foreground="{ThemeResource MutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- Collections section (collapsible) — last per v1.5 reorder. -->
                        <StackPanel x:Name="CollectionsHeader" Visibility="Collapsed" Margin="0,4,0,8">
                            <Button Tag="Collections" Click="OnSidebarSectionToggle"
                                    Style="{StaticResource SidebarSectionHeaderStyle}">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="COLLECTIONS" CharacterSpacing="100"/>
                                    <TextBlock x:Name="CollectionsChevron" Grid.Column="1"
                                               Text="⌄" FontSize="12"/>
                                </Grid>
                            </Button>
                            <ItemsRepeater x:Name="CollectionsRepeater"
                                           Visibility="Collapsed">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:Collection">
                                        <Button Style="{StaticResource NavItemStyle}"
                                                Tag="{Binding Id}"
                                                Click="OnNavCollection">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <StackPanel Orientation="Horizontal" Spacing="8">
                                                    <TextBlock Text="⊞" VerticalAlignment="Center"
                                                               Foreground="{ThemeResource MutedBrush}"/>
                                                    <TextBlock Text="{Binding Name}"
                                                               TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                </StackPanel>
                                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                                    <TextBlock Text="{Binding MovieCount}" FontSize="11"
                                                               Foreground="{ThemeResource MutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                    </StackPanel>
                </ScrollViewer>

                <!-- Stats + Theme footer — wrapped in a rounded card so it
                     reads as a deliberate panel rather than an orphaned strip. -->
                <Border x:Name="FooterPanel" Grid.Row="2"
                        Margin="10,8,10,10" Padding="14,10"
                        Background="{ThemeResource CardBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        BorderThickness="1" CornerRadius="10">
                    <StackPanel>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <TextBlock Text="Total Runtime" Foreground="{ThemeResource MutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="StatRuntime" Grid.Column="1" Text="—"
                                       HorizontalAlignment="Right" FontSize="12"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </Grid>
                        <Grid Margin="0,2">
                            <Grid.ColumnDefinitions><ColumnDefinition/><ColumnDefinition/></Grid.ColumnDefinitions>
                            <TextBlock Text="Avg Rating" Foreground="{ThemeResource MutedBrush}" FontSize="12"/>
                            <TextBlock x:Name="StatRating" Grid.Column="1" Text="—"
                                       HorizontalAlignment="Right" FontSize="12"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </Grid>
                        <!-- Theme + Help + Collapse row -->
                        <Grid Margin="0,8,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="Theme" Foreground="{ThemeResource MutedBrush}"
                                       FontSize="12" VerticalAlignment="Center"/>
                            <Button x:Name="ThemeBtn" Grid.Column="1" Click="OnToggleTheme"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="4" FontSize="14"/>
                            <Button Grid.Column="2" Click="OnHelpClick"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="4" FontSize="13" Margin="4,0,0,0">
                                <TextBlock Text="?" FontWeight="Bold"/>
                            </Button>
                            <Button x:Name="SidebarToggleBtn" Grid.Column="3" Click="OnToggleSidebar"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="4" FontSize="14" Margin="4,0,0,0">
                                <TextBlock x:Name="SidebarToggleIcon" Text="⮜"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Frame x:Name="ContentFrame" Grid.Column="1" Background="{ThemeResource BgBrush}"/>

            <!-- Floating re-open button when sidebar collapsed -->
            <Button x:Name="SidebarReopenBtn" Grid.Column="1"
                    Click="OnToggleSidebar"
                    HorizontalAlignment="Left" VerticalAlignment="Top"
                    Margin="8,8,0,0" Visibility="Collapsed"
                    Background="{ThemeResource CardBrush}"
                    BorderBrush="{ThemeResource BorderBrush}"
                    Padding="6,4" FontSize="14"
                    ToolTipService.ToolTip="Show sidebar">
                <TextBlock Text="☰"/>
            </Button>

            <!-- ═══ TOAST ═══ -->
            <Border x:Name="ToastBorder" Grid.Column="1"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,20,20" Visibility="Collapsed"
                    Background="{ThemeResource ToastBgBrush}" CornerRadius="10" Padding="16,12"
                    BorderBrush="{StaticResource BrandPurpleBrush}" BorderThickness="1">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="ToastText" Foreground="{ThemeResource TextBrush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button x:Name="ToastActionBtn" Click="OnToastActionClick"
                            Visibility="Collapsed"
                            Background="{StaticResource BrandPurpleBrush}"
                            Foreground="#FFFFFF" BorderThickness="0"
                            CornerRadius="6" Padding="10,4" FontSize="12"
                            VerticalAlignment="Center"/>
                    <Button Content="✕" Click="OnToastDismiss"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource MutedBrush}" Padding="4" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
