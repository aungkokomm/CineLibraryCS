<Window
    x:Class="CineLibraryCS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS"
    xmlns:models="using:CineLibraryCS.Models"
    xmlns:views="using:CineLibraryCS.Views"
    Title="CineLibrary">

    <Grid x:Name="RootGrid" Background="{ThemeResource BgBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ CUSTOM TITLEBAR (drag region) ═══ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <!-- v2.5.1 — reopen-sidebar toggle lives here so it never
                     overlaps the page title when the sidebar is collapsed. -->
                <Button x:Name="SidebarReopenBtn" Click="OnToggleSidebar"
                        Visibility="Collapsed"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{ThemeResource MutedBrush}"
                        Padding="6,4" CornerRadius="6"
                        VerticalAlignment="Center"
                        ToolTipService.ToolTip="Show sidebar">
                    <FontIcon Glyph="&#xE89F;" FontSize="14"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                </Button>
                <Image Source="ms-appx:///Assets/icon.ico"
                       Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="CineLibrary" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>

        </Grid>

        <!-- ═══ MAIN CONTENT ROW ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="260"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <Grid x:Name="SidebarGrid" Grid.Column="0" Background="{ThemeResource SidebarBrush}">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo — v2.6 wordmark with a gold ▶ accent inside a
                     purple tile. Click opens the About dialog. -->
                <Button Grid.Row="0" Click="OnAboutClick"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,12,14,8">
                    <StackPanel x:Name="LogoPanel" Orientation="Horizontal" Spacing="10">
                        <Border Background="{StaticResource BrandPurpleBrush}"
                                CornerRadius="8" Width="32" Height="32">
                            <TextBlock Text="▶" FontSize="14" FontWeight="Bold"
                                       Foreground="{StaticResource BrandGoldBrush}"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Margin="2,0,0,0"/>
                        </Border>
                        <StackPanel x:Name="LogoTextPanel" VerticalAlignment="Center"
                                    Orientation="Horizontal" Spacing="0">
                            <TextBlock Text="Cine" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                            <TextBlock Text="Library" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandPurpleBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Nav -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NavPanel" Padding="8,0">

                        <!-- LIBRARY group (v1.9.3) -->
                        <TextBlock Text="LIBRARY" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <!-- All Movies -->
                        <Button x:Name="BtnAllMovies" Style="{StaticResource NavItemStyle}"
                                Click="OnNavAllMovies">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE786;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="All Movies" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="TotalBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Favorites -->
                        <Button x:Name="BtnFavorites" Style="{StaticResource NavItemStyle}" Click="OnNavFavorites">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE734;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Foreground="#F5C518"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Favorites" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Watchlist (v1.3) -->
                        <Button x:Name="BtnWatchlist" Style="{StaticResource NavItemStyle}" Click="OnNavWatchlist">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE74C;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="To Watch" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="WatchlistBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- DISCOVER group (v1.9.3) -->
                        <TextBlock Text="DISCOVER" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <!-- Continue Watching (v1.8) -->
                        <Button x:Name="BtnContinueWatching" Style="{StaticResource NavItemStyle}"
                                Click="OnNavContinueWatching">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE768;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Continue Watching" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="ContinueWatchingBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Recently Added (v1.7) -->
                        <Button x:Name="BtnRecentlyAdded" Style="{StaticResource NavItemStyle}" Click="OnNavRecentlyAdded">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE823;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Recently Added" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Random Pick (v1.7) -->
                        <Button x:Name="BtnRandomPick" Style="{StaticResource NavItemStyle}" Click="OnNavRandomPick">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8B1;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Surprise me" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- BROWSE group (v2.1) — banner-style category pages -->
                        <TextBlock Text="BROWSE" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <Button x:Name="BtnBrowseGenre" Style="{StaticResource NavItemStyle}"
                                Click="OnNavBrowseGenre">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8EC;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="By Genre" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnBrowseDecade" Style="{StaticResource NavItemStyle}"
                                Click="OnNavBrowseDecade">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE787;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="By Decade" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnBrowseRating" Style="{StaticResource NavItemStyle}"
                                Click="OnNavBrowseRating">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE735;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="By Rating" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnCollections" Style="{StaticResource NavItemStyle}"
                                Click="OnNavCollections">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8B7;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Collections" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- TOOLS group (v1.9.3) -->
                        <TextBlock Text="TOOLS" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <!-- Statistics (v1.4.1) -->
                        <Button x:Name="BtnStatistics" Style="{StaticResource NavItemStyle}" Click="OnNavStatistics">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE9D9;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Statistics" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Drives -->
                        <Button x:Name="BtnDrives" Style="{StaticResource NavItemStyle}" Click="OnNavDrives">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xEDA2;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Drives" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="DrivesBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- My Lists section (v1.9.2) — user-defined custom lists.
                             v2.5.1: header restyled as a quiet group label
                             matching LIBRARY / DISCOVER / BROWSE / TOOLS. -->
                        <StackPanel x:Name="UserListsHeader" Margin="0,8,0,0">
                            <Grid Margin="8,4,4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Tag="UserLists" Click="OnSidebarSectionToggle"
                                        Style="{StaticResource SidebarSectionHeaderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="MY LISTS" CharacterSpacing="150"/>
                                        <TextBlock x:Name="UserListsChevron" Grid.Column="1"
                                                   Text="⌃" FontSize="11" Margin="6,0,0,0"/>
                                    </Grid>
                                </Button>
                                <Button Grid.Column="1" Click="OnNewUserList"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="6,0" Margin="2,0,0,0"
                                        VerticalAlignment="Stretch"
                                        ToolTipService.ToolTip="Create a new list">
                                    <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                               Foreground="{ThemeResource MutedBrush}"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                            <StackPanel x:Name="UserListsItemsPanel"/>
                        </StackPanel>

                        <!-- Libraries section (collapsible, custom header) -->
                        <StackPanel x:Name="LibrariesHeader" Visibility="Collapsed" Margin="0,8,0,0">
                            <Button Tag="Libraries" Click="OnSidebarSectionToggle"
                                    Style="{StaticResource SidebarSectionHeaderStyle}"
                                    Margin="8,4,8,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LIBRARIES" CharacterSpacing="150"/>
                                    <TextBlock x:Name="LibrariesChevron" Grid.Column="1"
                                               Text="⌃" FontSize="11" Margin="6,0,0,0"/>
                                </Grid>
                            </Button>
                            <ItemsRepeater x:Name="DrivesRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveInfo">
                                        <Button Style="{StaticResource NavItemStyle}"
                                                Tag="{Binding VolumeSerial}"
                                                Click="OnNavDriveItem">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                                         Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Style="{StaticResource BadgeStyle}">
                                                    <TextBlock Text="{Binding MovieCount}" FontSize="11"
                                                               Foreground="{ThemeResource MutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- v2.1: TOP GENRES + COLLECTIONS sub-sections removed.
                             Both are now first-class pages under the BROWSE section
                             (By Genre, Collections), which is richer (banner cards,
                             poster grid) than the previous flat sidebar list. -->

                    </StackPanel>
                </ScrollViewer>

                <!-- v2.5.1 footer: tool row only. Runtime / Avg Rating tiles
                     were moved out of the sidebar — they live on the
                     Statistics page where they have proper context. -->
                <Border x:Name="FooterPanel" Grid.Row="2"
                        Margin="10,8,10,10" Padding="0"
                        Background="Transparent"
                        BorderThickness="0">
                    <StackPanel Spacing="8">
                        <!-- Tool row — theme / help / collapse, all icon-only -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ThemeBtn" Grid.Column="1" Click="OnToggleTheme"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="6" FontSize="14"
                                    CornerRadius="6"/>
                            <Button Grid.Column="2" Click="OnHelpClick"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="6" FontSize="13" Margin="2,0,0,0"
                                    CornerRadius="6">
                                <FontIcon Glyph="&#xE897;" FontSize="14"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>
                            <Button x:Name="SidebarToggleBtn" Grid.Column="3" Click="OnToggleSidebar"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="6" FontSize="14" Margin="2,0,0,0"
                                    CornerRadius="6"
                                    ToolTipService.ToolTip="Collapse sidebar">
                                <FontIcon x:Name="SidebarToggleIcon" Glyph="&#xE8A0;" FontSize="16"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Frame x:Name="ContentFrame" Grid.Column="1" Background="{ThemeResource BgBrush}"/>

<!-- v2.5.1: reopen toggle moved into AppTitleBar above to avoid
                 overlapping the active page's title row. -->


            <!-- ═══ TOAST ═══ v2.6 — slides up from below on show -->
            <Border x:Name="ToastBorder" Grid.Column="1"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,20,20" Visibility="Collapsed"
                    Background="{ThemeResource ToastBgBrush}" CornerRadius="10" Padding="16,12"
                    BorderBrush="{StaticResource BrandPurpleBrush}" BorderThickness="1">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastSlide" Y="20"/>
                </Border.RenderTransform>
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <Border.Translation>0,0,32</Border.Translation>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="ToastText" Foreground="{ThemeResource TextBrush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button x:Name="ToastActionBtn" Click="OnToastActionClick"
                            Visibility="Collapsed"
                            Background="{StaticResource BrandPurpleBrush}"
                            Foreground="#FFFFFF" BorderThickness="0"
                            CornerRadius="6" Padding="10,4" FontSize="12"
                            VerticalAlignment="Center"/>
                    <Button Content="✕" Click="OnToastDismiss"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource MutedBrush}" Padding="4" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
