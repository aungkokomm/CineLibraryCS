<Window
    x:Class="CineLibraryCS.MainWindow"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS"
    xmlns:models="using:CineLibraryCS.Models"
    xmlns:views="using:CineLibraryCS.Views"
    Title="CineLibrary">

    <!-- Transparent root reveals the window's Mica backdrop. The content
         frame stays opaque (crisp pages); only the title bar and the floating
         sidebar card let Mica through. -->
    <Grid x:Name="RootGrid" Background="Transparent">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Solid opaque window fill, shown only when Mica is turned OFF in
             Settings. Theme-bound so it's always the right base colour. -->
        <Rectangle x:Name="MicaOffBackdrop" Grid.Row="0" Grid.RowSpan="2"
                   Fill="{ThemeResource BgBrush}" Visibility="Collapsed"/>

        <!-- ═══ CUSTOM TITLEBAR (drag region) ═══ -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            <StackPanel Grid.Column="0" Orientation="Horizontal" Spacing="8"
                        VerticalAlignment="Center" Margin="8,0,0,0">
                <!-- v2.5.1 — reopen-sidebar toggle lives here so it never
                     overlaps the page title when the sidebar is collapsed. -->
                <Button x:Name="SidebarReopenBtn" Click="OnToggleSidebar"
                        Visibility="Collapsed"
                        Background="Transparent" BorderThickness="0"
                        Foreground="{ThemeResource MutedBrush}"
                        Padding="6,4" CornerRadius="6"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Show sidebar"
                        ToolTipService.ToolTip="Show sidebar">
                    <FontIcon Glyph="&#xE89F;" FontSize="14"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                </Button>
                <Image Source="ms-appx:///Assets/icon.ico"
                       Width="16" Height="16" VerticalAlignment="Center"/>
                <TextBlock Text="CineLibrary" FontSize="12" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextBrush}" VerticalAlignment="Center"/>
            </StackPanel>

            <!-- Global search, centered in the title bar (interactive children
                 of the title-bar element receive input automatically). Drives
                 the Library page's search engine. -->
            <Grid Grid.Column="1" x:Name="TitleSearchHost"
                  HorizontalAlignment="Center" VerticalAlignment="Center"
                  Width="520" Margin="0,0,130,0" ColumnSpacing="6">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>
                <ComboBox x:Name="TitleScopeCombo" Grid.Column="0"
                          SelectionChanged="OnTitleScopeChanged"
                          SelectedIndex="0"
                          Height="32" MinWidth="84" VerticalAlignment="Center"
                          CornerRadius="8"
                          Background="{ThemeResource InputBgBrush}"
                          Foreground="{ThemeResource TextBrush}"
                          BorderBrush="{ThemeResource InputBorderBrush}"
                          ToolTipService.ToolTip="What the search matches">
                    <ComboBoxItem Tag="all"   Content="All"/>
                    <ComboBoxItem Tag="title" Content="Title"/>
                    <ComboBoxItem Tag="cast"  Content="Cast &amp; crew"/>
                </ComboBox>
                <AutoSuggestBox x:Name="TitleSearchBox" Grid.Column="1"
                                PlaceholderText="Search title, actor, director…"
                                QueryIcon="Find"
                                Height="32" VerticalAlignment="Center"
                                CornerRadius="8"
                                TextChanged="OnTitleSearchChanged"
                                Background="{ThemeResource InputBgBrush}"
                                BorderBrush="{ThemeResource InputBorderBrush}"
                                Foreground="{ThemeResource TextBrush}"/>
            </Grid>

        </Grid>

        <!-- ═══ MAIN CONTENT ROW ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="SidebarCol" Width="252"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>

            <!-- ═══ SIDEBAR ═══ -->
            <!-- v2.9.3 — the sidebar is a floating rounded card: it sits
                 inset from the window edges (margin) on its own rounded
                 surface, like the Claude desktop app. The gap reveals the
                 window background behind it. Nothing inside the pane
                 changed — only this wrapper + the column width (bumped to
                 keep the inner content the same 240 px as before). -->
            <Border x:Name="SidebarCard" Grid.Column="0"
                    Margin="8,6,4,8" CornerRadius="10"
                    Background="{ThemeResource SidebarBrush}"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                    Translation="0,0,24">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
            <Grid x:Name="SidebarGrid">
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <!-- Logo — v2.9 wordmark with a gold ▶ accent inside a
                     purple tile. The tile uses a deep violet gradient + a
                     faint top-edge highlight so it reads as a crisp, lifted
                     badge instead of the flat pale lavender it was before.
                     Click opens the About dialog. -->
                <Button Grid.Row="0" Click="OnAboutClick"
                        Background="Transparent" BorderThickness="0"
                        HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                        Padding="14,12,14,8">
                    <StackPanel x:Name="LogoPanel" Orientation="Horizontal" Spacing="10">
                        <Border CornerRadius="9" Width="32" Height="32"
                                BorderBrush="#55FFFFFF" BorderThickness="1">
                            <Border.Background>
                                <!-- Vivid violet gradient: bright purple top,
                                     deep indigo-violet base — echoes the app
                                     icon's rich purple body. -->
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0.4,1">
                                    <GradientStop Offset="0" Color="#C13AEB"/>
                                    <GradientStop Offset="1" Color="#5B21B6"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <!-- Child is clipped to the parent's corner radius. -->
                            <Grid>
                                <!-- Glossy top sheen — soft white highlight over
                                     the upper half, fading to nothing. -->
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0"    Color="#4DFFFFFF"/>
                                            <GradientStop Offset="0.55" Color="#00FFFFFF"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <!-- Tiny sparkle, top-left, nodding to the icon. -->
                                <TextBlock Text="✦" FontSize="7" Foreground="#CCFFFFFF"
                                           HorizontalAlignment="Left" VerticalAlignment="Top"
                                           Margin="5,4,0,0"/>
                                <!-- Glossy white play triangle (vector, crisp). -->
                                <Polygon Points="0,0 0,13 11,6.5"
                                         HorizontalAlignment="Center" VerticalAlignment="Center"
                                         Margin="2,0,0,0">
                                    <Polygon.Fill>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#FFFFFF"/>
                                            <GradientStop Offset="1" Color="#E9D5FF"/>
                                        </LinearGradientBrush>
                                    </Polygon.Fill>
                                </Polygon>
                            </Grid>
                        </Border>
                        <StackPanel x:Name="LogoTextPanel" VerticalAlignment="Center"
                                    Orientation="Horizontal" Spacing="0">
                            <TextBlock Text="Cine" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                            <TextBlock Text="Library" FontSize="15" FontWeight="SemiBold"
                                       Foreground="{StaticResource BrandPurpleBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Button>

                <!-- Nav -->
                <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
                    <StackPanel x:Name="NavPanel" Padding="8,0">

                        <!-- LIBRARY group (v1.9.3) -->
                        <TextBlock Text="LIBRARY" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <!-- All Movies -->
                        <Button x:Name="BtnAllMovies" Style="{StaticResource NavItemStyle}"
                                Click="OnNavAllMovies">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE786;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="All Movies" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="TotalBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- All TV Shows (v2.8) -->
                        <Button x:Name="BtnTvShows" Style="{StaticResource NavItemStyle}" Click="OnNavTvShows">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE7F4;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="All TV Shows" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="TvShowsBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Favorites -->
                        <Button x:Name="BtnFavorites" Style="{StaticResource NavItemStyle}" Click="OnNavFavorites">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE734;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Foreground="#F5C518"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Favorites" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Watchlist (v1.3) -->
                        <Button x:Name="BtnWatchlist" Style="{StaticResource NavItemStyle}" Click="OnNavWatchlist">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE74C;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="To Watch" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="WatchlistBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Notes (v2.8.2) — every movie that carries a note -->
                        <Button x:Name="BtnNotes" Style="{StaticResource NavItemStyle}" Click="OnNavNotes">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE70B;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Notes" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="NotesBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Watched & Gone (v3.3) — records of watched-then-deleted movies.
                             Hidden until the first record exists. -->
                        <Button x:Name="BtnWatchedGone" Style="{StaticResource NavItemStyle}"
                                Click="OnNavWatchedGone" Visibility="Collapsed">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE7B8;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Watched &amp; Gone" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="WatchedGoneBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- DISCOVER group (v1.9.3) -->
                        <TextBlock Text="DISCOVER" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <!-- Continue Watching (v1.8) -->
                        <Button x:Name="BtnContinueWatching" Style="{StaticResource NavItemStyle}"
                                Click="OnNavContinueWatching">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE768;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Continue Watching" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="ContinueWatchingBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Recently Added (v1.7) -->
                        <Button x:Name="BtnRecentlyAdded" Style="{StaticResource NavItemStyle}" Click="OnNavRecentlyAdded">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE823;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Recently Added" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Recently Watched (v2.9) -->
                        <Button x:Name="BtnRecentlyWatched" Style="{StaticResource NavItemStyle}"
                                Click="OnNavRecentlyWatched">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xE823;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Recently Watched" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="RecentlyWatchedBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- Random Pick (v1.7) -->
                        <Button x:Name="BtnRandomPick" Style="{StaticResource NavItemStyle}" Click="OnNavRandomPick">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8B1;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Surprise me" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- On This Day (v2.9) — hidden when nothing today.
                             Click opens a dialog with the matches: movies you
                             watched on this date in past years, and films
                             released on this date in past years. -->
                        <Button x:Name="BtnOnThisDay" Style="{StaticResource NavItemStyle}"
                                Click="OnNavOnThisDay" Visibility="Collapsed">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE787;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="On This Day" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- BROWSE group (v2.1) — banner-style category pages -->
                        <TextBlock Text="BROWSE" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <Button x:Name="BtnBrowseGenre" Style="{StaticResource NavItemStyle}"
                                Click="OnNavBrowseGenre">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8EC;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="By Genre" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnBrowseDecade" Style="{StaticResource NavItemStyle}"
                                Click="OnNavBrowseDecade">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE787;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="By Decade" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnBrowseRating" Style="{StaticResource NavItemStyle}"
                                Click="OnNavBrowseRating">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE735;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="By Rating" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button x:Name="BtnCollections" Style="{StaticResource NavItemStyle}"
                                Click="OnNavCollections">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8B7;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Collections" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- TOOLS group (v1.9.3) -->
                        <TextBlock Text="TOOLS" Style="{StaticResource SidebarGroupLabelStyle}"/>

                        <!-- Statistics (v1.4.1) -->
                        <Button x:Name="BtnStatistics" Style="{StaticResource NavItemStyle}" Click="OnNavStatistics">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE9D9;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Statistics" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Drives -->
                        <Button x:Name="BtnDrives" Style="{StaticResource NavItemStyle}" Click="OnNavDrives">
                            <Grid HorizontalAlignment="Stretch">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <StackPanel Orientation="Horizontal" Spacing="10">
                                    <FontIcon Glyph="&#xEDA2;" FontSize="15"
                                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                              VerticalAlignment="Center"/>
                                    <TextBlock Text="Drives" VerticalAlignment="Center"/>
                                </StackPanel>
                                <Border Grid.Column="1" Style="{StaticResource BadgeStyle}">
                                    <TextBlock x:Name="DrivesBadge" Text="0" FontSize="11"
                                               Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
                                </Border>
                            </Grid>
                        </Button>

                        <!-- v2.9 — Backup / restore personal state.
                             Opens a small dialog with Export / Import. -->
                        <Button x:Name="BtnBackup" Style="{StaticResource NavItemStyle}"
                                Click="OnNavBackup">
                            <StackPanel Orientation="Horizontal" Spacing="10">
                                <FontIcon Glyph="&#xE8C8;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Backup" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- My Lists section (v1.9.2) — user-defined custom lists.
                             v2.5.1: header restyled as a quiet group label
                             matching LIBRARY / DISCOVER / BROWSE / TOOLS. -->
                        <StackPanel x:Name="UserListsHeader" Margin="0,8,0,0">
                            <Grid Margin="8,4,4,2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*"/>
                                    <ColumnDefinition Width="Auto"/>
                                </Grid.ColumnDefinitions>
                                <Button Grid.Column="0" Tag="UserLists" Click="OnSidebarSectionToggle"
                                        Style="{StaticResource SidebarSectionHeaderStyle}">
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="MY LISTS" CharacterSpacing="150"/>
                                        <TextBlock x:Name="UserListsChevron" Grid.Column="1"
                                                   Text="⌃" FontSize="11" Margin="6,0,0,0"/>
                                    </Grid>
                                </Button>
                                <Button Grid.Column="1" Click="OnNewUserList"
                                        Background="Transparent" BorderThickness="0"
                                        Padding="6,0" Margin="2,0,0,0"
                                        VerticalAlignment="Stretch"
                                        ToolTipService.ToolTip="Create a new list">
                                    <TextBlock Text="+" FontSize="14" FontWeight="Bold"
                                               Foreground="{ThemeResource MutedBrush}"
                                               VerticalAlignment="Center"/>
                                </Button>
                            </Grid>
                            <StackPanel x:Name="UserListsItemsPanel"/>
                        </StackPanel>

                        <!-- v2.9 — Tags section. Collapsible like My Lists.
                             Populated from DB by RefreshSidebar; hidden when
                             no tags exist yet. -->
                        <StackPanel x:Name="TagsHeader" Visibility="Collapsed" Margin="0,8,0,0">
                            <Button Tag="Tags" Click="OnSidebarSectionToggle"
                                    Style="{StaticResource SidebarSectionHeaderStyle}"
                                    Margin="8,4,8,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="🏷  TAGS" CharacterSpacing="150"/>
                                    <TextBlock x:Name="TagsChevron" Grid.Column="1"
                                               Text="⌃" FontSize="11" Margin="6,0,0,0"/>
                                </Grid>
                            </Button>
                            <StackPanel x:Name="TagsItemsPanel"/>
                        </StackPanel>

                        <!-- Libraries section (collapsible, custom header) -->
                        <StackPanel x:Name="LibrariesHeader" Visibility="Collapsed" Margin="0,8,0,0">
                            <Button Tag="Libraries" Click="OnSidebarSectionToggle"
                                    Style="{StaticResource SidebarSectionHeaderStyle}"
                                    Margin="8,4,8,2">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="LIBRARIES" CharacterSpacing="150"/>
                                    <TextBlock x:Name="LibrariesChevron" Grid.Column="1"
                                               Text="⌃" FontSize="11" Margin="6,0,0,0"/>
                                </Grid>
                            </Button>
                            <ItemsRepeater x:Name="DrivesRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Vertical"/>
                                </ItemsRepeater.Layout>
                                <ItemsRepeater.ItemTemplate>
                                    <DataTemplate x:DataType="models:DriveInfo">
                                        <Button Style="{StaticResource NavItemStyle}"
                                                Tag="{Binding VolumeSerial}"
                                                Click="OnNavDriveItem">
                                            <Grid HorizontalAlignment="Stretch">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                <Ellipse Grid.Column="0" Width="8" Height="8"
                                                         Margin="0,0,8,0" VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{Binding IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Grid.Column="1" Text="{Binding Label}"
                                                           TextTrimming="CharacterEllipsis" VerticalAlignment="Center"/>
                                                <Border Grid.Column="2" Style="{StaticResource BadgeStyle}">
                                                    <TextBlock Text="{Binding MovieCount}" FontSize="11"
                                                               Foreground="{ThemeResource MutedBrush}"
                                                               HorizontalAlignment="Center"/>
                                                </Border>
                                            </Grid>
                                        </Button>
                                    </DataTemplate>
                                </ItemsRepeater.ItemTemplate>
                            </ItemsRepeater>
                        </StackPanel>

                        <!-- v2.1: TOP GENRES + COLLECTIONS sub-sections removed.
                             Both are now first-class pages under the BROWSE section
                             (By Genre, Collections), which is richer (banner cards,
                             poster grid) than the previous flat sidebar list. -->

                    </StackPanel>
                </ScrollViewer>

                <!-- v2.5.1 footer: tool row only. Runtime / Avg Rating tiles
                     were moved out of the sidebar — they live on the
                     Statistics page where they have proper context. -->
                <Border x:Name="FooterPanel" Grid.Row="2"
                        Margin="10,8,10,10" Padding="0"
                        Background="Transparent"
                        BorderThickness="0">
                    <StackPanel Spacing="8">
                        <!-- Tool row — theme / settings / help / collapse, all icon-only.
                             v3.0.0: theme button is now a monochrome FontIcon (matches
                             the others) instead of a colour emoji, and a Settings gear
                             was added. -->
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button x:Name="ThemeBtn" Grid.Column="1" Click="OnToggleTheme"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="6" CornerRadius="6"
                                    AutomationProperties.Name="Switch theme"
                                    ToolTipService.ToolTip="Switch theme">
                                <FontIcon x:Name="ThemeIcon" Glyph="&#xE706;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>
                            <Button x:Name="SettingsBtn" Grid.Column="2" Click="OnSettingsClick"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="6" Margin="2,0,0,0" CornerRadius="6"
                                    AutomationProperties.Name="Settings"
                                    ToolTipService.ToolTip="Settings">
                                <FontIcon Glyph="&#xE713;" FontSize="15"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>
                            <Button Grid.Column="3" Click="OnHelpClick"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="6" Margin="2,0,0,0" CornerRadius="6"
                                    AutomationProperties.Name="Keyboard shortcuts"
                                    ToolTipService.ToolTip="Keyboard shortcuts">
                                <FontIcon Glyph="&#xE897;" FontSize="14"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>
                            <Button x:Name="SidebarToggleBtn" Grid.Column="4" Click="OnToggleSidebar"
                                    Background="Transparent" BorderThickness="0"
                                    Foreground="{ThemeResource MutedBrush}"
                                    Padding="6" Margin="2,0,0,0" CornerRadius="6"
                                    AutomationProperties.Name="Collapse sidebar"
                                    ToolTipService.ToolTip="Collapse sidebar">
                                <FontIcon x:Name="SidebarToggleIcon" Glyph="&#xE8A0;" FontSize="16"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <!-- Floating OPAQUE content panel on the Mica window: Mica frames it
                 (and the sidebar) for the full Mica look, while the scrolling
                 grid stays opaque so it never composites over Mica → fast. -->
            <Border Grid.Column="1" Background="{ThemeResource BgBrush}"
                    Margin="4,6,8,8" CornerRadius="12"
                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                    Translation="0,0,24">
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <Frame x:Name="ContentFrame" Background="Transparent"/>
            </Border>

<!-- v2.5.1: reopen toggle moved into AppTitleBar above to avoid
                 overlapping the active page's title row. -->


            <!-- ═══ TOAST ═══ v2.6 — slides up from below on show -->
            <Border x:Name="ToastBorder" Grid.Column="1"
                    VerticalAlignment="Bottom" HorizontalAlignment="Right"
                    Margin="0,0,20,20" Visibility="Collapsed"
                    Background="{ThemeResource ToastBgBrush}" CornerRadius="10" Padding="16,12"
                    BorderBrush="{StaticResource BrandPurpleBrush}" BorderThickness="1">
                <Border.RenderTransform>
                    <TranslateTransform x:Name="ToastSlide" Y="20"/>
                </Border.RenderTransform>
                <Border.Shadow>
                    <ThemeShadow/>
                </Border.Shadow>
                <Border.Translation>0,0,32</Border.Translation>
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock x:Name="ToastText" Foreground="{ThemeResource TextBrush}"
                               VerticalAlignment="Center" FontSize="13"/>
                    <Button x:Name="ToastActionBtn" Click="OnToastActionClick"
                            Visibility="Collapsed"
                            Background="{StaticResource BrandPurpleBrush}"
                            Foreground="#FFFFFF" BorderThickness="0"
                            CornerRadius="6" Padding="10,4" FontSize="12"
                            VerticalAlignment="Center"/>
                    <Button Content="✕" Click="OnToastDismiss"
                            Background="Transparent" BorderThickness="0"
                            Foreground="{ThemeResource MutedBrush}" Padding="4" FontSize="12"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Window>
