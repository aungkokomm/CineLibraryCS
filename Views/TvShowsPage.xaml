<Page
    x:Class="CineLibraryCS.Views.TvShowsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS.Views"
    xmlns:models="using:CineLibraryCS.Models"
    Background="{ThemeResource BgBrush}">

    <Page.Resources>
        <DataTemplate x:Key="EpisodeCardTemplate" x:DataType="models:TvEpisodeItem">
            <local:TvEpisodeCard Episode="{x:Bind}"/>
        </DataTemplate>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header with back strip -->
        <Grid Grid.Row="0" Padding="24,8,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn" Grid.Column="0" Click="OnBackClick"
                    Background="{ThemeResource InputBgBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="10,6" Height="36" Margin="0,0,12,0"
                    VerticalAlignment="Center" Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="‹" FontSize="18" FontWeight="Bold"
                               Foreground="{ThemeResource TextBrush}"/>
                    <TextBlock x:Name="BackLabel" Text="Back" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}"/>
                </StackPanel>
            </Button>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock x:Name="TitleText" Text="ALL TV SHOWS" FontSize="18" FontWeight="Bold"
                           Foreground="{ThemeResource TextBrush}" CharacterSpacing="100"/>
                <TextBlock x:Name="SubText" Text="" FontSize="12"
                           Foreground="{ThemeResource MutedBrush}"/>
            </StackPanel>
        </Grid>

        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
            <Grid>
                <!-- LEVEL 1: Continue Watching row (v2.9) + Shows grid -->
                <StackPanel x:Name="ShowsLevelHost" Spacing="0">
                    <!-- v2.9 — "Continue Watching" row: shows the user has
                         started but not finished, with the next-unwatched
                         episode label. Built in code-behind; hidden when
                         empty. -->
                    <StackPanel x:Name="ContinueWatchingHost" Visibility="Collapsed"
                                Spacing="6" Margin="0,0,0,18">
                        <TextBlock Text="▶ CONTINUE WATCHING"
                                   Margin="24,4,24,0"
                                   FontSize="12" FontWeight="SemiBold" CharacterSpacing="150"
                                   Opacity="0.75"
                                   Foreground="{ThemeResource MutedBrush}"/>
                        <ScrollViewer HorizontalScrollBarVisibility="Auto"
                                      VerticalScrollBarVisibility="Disabled"
                                      HorizontalScrollMode="Enabled"
                                      VerticalScrollMode="Disabled"
                                      Height="312" Padding="24,0,24,0">
                            <ItemsRepeater x:Name="ContinueWatchingRepeater">
                                <ItemsRepeater.Layout>
                                    <StackLayout Orientation="Horizontal" Spacing="14"/>
                                </ItemsRepeater.Layout>
                            </ItemsRepeater>
                        </ScrollViewer>
                    </StackPanel>

                    <ItemsRepeater x:Name="ShowsRepeater" Margin="24,0,24,24">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="170" MinItemHeight="300"
                                               MinColumnSpacing="14" MinRowSpacing="14"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TvShowListItem">
                                <local:TvShowCard Show="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- LEVEL 2: Show header + Seasons grid -->
                <StackPanel x:Name="SeasonsPanel" Visibility="Collapsed" Spacing="0">
                    <!-- Show-detail header (v2.8) -->
                    <Grid x:Name="ShowHeader" Margin="24,0,24,20">
                        <Border CornerRadius="14" Background="{ThemeResource HeroBgBrush}">
                            <Grid>
                                <Image x:Name="ShowFanart" Stretch="UniformToFill" Opacity="0.28"/>
                                <Border>
                                    <Border.Background>
                                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                            <GradientStop Offset="0" Color="#CC000000"/>
                                            <GradientStop Offset="1" Color="#F2000000"/>
                                        </LinearGradientBrush>
                                    </Border.Background>
                                </Border>
                                <Grid Padding="20" ColumnSpacing="20">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="Auto"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <!-- Poster -->
                                    <Border Grid.Column="0" Width="130" Height="195" CornerRadius="10"
                                            VerticalAlignment="Top"
                                            Background="{ThemeResource PlaceholderBgBrush}">
                                        <Grid>
                                            <TextBlock Text="📺" FontSize="40" Opacity="0.6"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                            <Image x:Name="ShowPoster" Stretch="UniformToFill"/>
                                        </Grid>
                                    </Border>
                                    <!-- Meta -->
                                    <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top">
                                        <TextBlock x:Name="ShowTitle" FontSize="26" FontWeight="Bold"
                                                   Foreground="White" TextWrapping="Wrap"/>
                                        <StackPanel x:Name="ShowMetaRow" Orientation="Horizontal" Spacing="14">
                                            <TextBlock x:Name="ShowYear" FontSize="13" Foreground="#D8D8D8"/>
                                            <TextBlock x:Name="ShowRating" FontSize="13" Foreground="#F59E0B"/>
                                            <TextBlock x:Name="ShowStatus" FontSize="13" Foreground="#A78BFA"/>
                                            <TextBlock x:Name="ShowProgress" FontSize="13" Foreground="#D8D8D8"/>
                                        </StackPanel>
                                        <TextBlock x:Name="ShowPlot" FontSize="13" Foreground="#E0E0E0"
                                                   TextWrapping="Wrap" MaxLines="4"
                                                   TextTrimming="CharacterEllipsis" MaxWidth="720"/>
                                        <StackPanel x:Name="ShowGenres" Orientation="Horizontal" Spacing="6"/>
                                        <!-- Action buttons -->
                                        <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,4,0,0">
                                            <Button x:Name="PlayNextBtn" Click="OnPlayNext"
                                                    Background="{StaticResource BrandPurpleBrush}" Foreground="White"
                                                    BorderThickness="0" CornerRadius="8" Padding="16,7"
                                                    FontWeight="SemiBold"/>
                                            <Button x:Name="ShowFavBtn" Click="OnToggleShowFavorite"
                                                    Background="#22FFFFFF" Foreground="White"
                                                    BorderThickness="0" CornerRadius="8" Padding="14,7"/>
                                            <Button x:Name="ShowWatchlistBtn" Click="OnToggleShowWatchlist"
                                                    Background="#22FFFFFF" Foreground="White"
                                                    BorderThickness="0" CornerRadius="8" Padding="14,7"/>
                                            <Button x:Name="ShowListsBtn" Content="📑 Add to list"
                                                    Background="#22FFFFFF" Foreground="White"
                                                    BorderThickness="0" CornerRadius="8" Padding="14,7">
                                                <Button.Flyout>
                                                    <MenuFlyout x:Name="ShowListsFlyout" Placement="Bottom"
                                                                Opening="OnShowListsFlyoutOpening"/>
                                                </Button.Flyout>
                                            </Button>
                                        </StackPanel>

                                        <!-- v2.9 — show tags row. Chips
                                             with ✕ to remove, "+ Add tag"
                                             autocomplete suggests existing
                                             tags and accepts new names.
                                             Backend mirrors movie tags. -->
                                        <StackPanel x:Name="ShowTagsRow" Orientation="Horizontal" Spacing="6"
                                                    Margin="0,2,0,0">
                                            <TextBlock Text="🏷" FontSize="13"
                                                       Foreground="#D8D8D8"
                                                       VerticalAlignment="Center" Opacity="0.8"/>
                                            <ItemsControl x:Name="ShowTagChipsRepeater">
                                                <ItemsControl.ItemsPanel>
                                                    <ItemsPanelTemplate>
                                                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                                                    </ItemsPanelTemplate>
                                                </ItemsControl.ItemsPanel>
                                            </ItemsControl>
                                            <Button x:Name="AddShowTagBtn" Click="OnAddShowTagClick"
                                                    Background="#22FFFFFF"
                                                    BorderBrush="#33FFFFFF"
                                                    BorderThickness="1" CornerRadius="12"
                                                    Padding="10,3"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="+ Add tag" FontSize="11"
                                                           Foreground="#D8D8D8"/>
                                            </Button>
                                            <AutoSuggestBox x:Name="AddShowTagBox" Visibility="Collapsed"
                                                            PlaceholderText="Tag name (Enter to add)"
                                                            Width="180"
                                                            QuerySubmitted="OnAddShowTagSubmitted"
                                                            TextChanged="OnAddShowTagTextChanged"
                                                            LostFocus="OnAddShowTagBlur"
                                                            VerticalAlignment="Center"/>
                                        </StackPanel>
                                        <!-- Cast strip -->
                                        <ItemsRepeater x:Name="CastRepeater" Margin="0,6,0,0">
                                            <ItemsRepeater.Layout>
                                                <StackLayout Orientation="Horizontal" Spacing="14"/>
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:Actor">
                                                    <StackPanel Width="70" Spacing="4">
                                                        <Border Width="64" Height="64" CornerRadius="32"
                                                                Background="#33FFFFFF">
                                                            <Grid>
                                                                <TextBlock Text="{x:Bind Initials}" FontSize="20"
                                                                           FontWeight="SemiBold" Foreground="White"
                                                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                                                <Border CornerRadius="32">
                                                                    <Image Stretch="UniformToFill"
                                                                           Source="{x:Bind ThumbBitmap, Mode=OneWay}"/>
                                                                </Border>
                                                            </Grid>
                                                        </Border>
                                                        <TextBlock Text="{x:Bind Name}" FontSize="10"
                                                                   Foreground="#E0E0E0" TextAlignment="Center"
                                                                   TextWrapping="WrapWholeWords" MaxLines="2"/>
                                                    </StackPanel>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </StackPanel>
                                </Grid>
                            </Grid>
                        </Border>
                    </Grid>

                    <!-- v2.8 — inline season sections: each season is a header
                         + a wrap of episode cards, built in code-behind. No
                         drill-down; you scroll the whole show on one page. -->
                    <StackPanel x:Name="SeasonSectionsHost" Margin="0,0,0,24" Spacing="18"/>
                </StackPanel>

                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,80,0,24" Spacing="8">
                    <TextBlock Text="📺" FontSize="48" HorizontalAlignment="Center" Opacity="0.7"/>
                    <TextBlock x:Name="EmptyTitle" Text="No TV shows yet"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyHint"
                               Text="Add a drive whose folders contain tvshow.nfo (MediaElch-scraped shows), then Update Database."
                               FontSize="12" Foreground="{ThemeResource MutedBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="420"/>
                </StackPanel>
            </Grid>
        </ScrollViewer>
    </Grid>
</Page>
