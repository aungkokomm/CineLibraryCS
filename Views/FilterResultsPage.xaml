<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CineLibraryCS.Views.FilterResultsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS.Views"
    xmlns:models="using:CineLibraryCS.Models"
    Background="{ThemeResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Grid Grid.Row="0" Padding="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BackToggleBtn" Grid.Column="0" Click="OnBackToggleClick"
                    Background="{ThemeResource InputBgBrush}" BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8" Width="36" Height="36"
                    VerticalAlignment="Center" Margin="0,0,12,0" ToolTipService.ToolTip="Show sidebar" Visibility="Collapsed">
                <TextBlock Text="‹" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextBrush}"/>
            </Button>

            <TextBlock Grid.Column="1" x:Name="PageTitleText" Text="Filter Results" FontSize="18" FontWeight="Bold" 
                       Foreground="{ThemeResource TextBrush}" CharacterSpacing="100" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Click="OnClearFilterClick" Background="{ThemeResource InputBgBrush}" 
                    BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" CornerRadius="8" 
                    Padding="12,8" Content="✕ Clear Filter" Foreground="{ThemeResource TextBrush}"/>
        </Grid>

        <!-- Filter Badge -->
        <Border Grid.Row="1" Background="{ThemeResource SidebarBrush}" Padding="24,12" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="0,1,0,1">
            <StackPanel Orientation="Horizontal" Spacing="12">
                <TextBlock Text="Filtering by:" FontSize="12" Foreground="{ThemeResource MutedBrush}" VerticalAlignment="Center"/>
                <Border Background="{ThemeResource AccentBrush}" CornerRadius="4" Padding="8,4">
                    <TextBlock x:Name="FilterBadgeText" Text="..." FontSize="12" FontWeight="SemiBold" Foreground="White"/>
                </Border>
            </StackPanel>
        </Border>

        <!-- Movie List -->
        <Grid Grid.Row="2">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <ListView x:Name="MoviesListView" Padding="0,16,0,0" SelectionMode="Single" 
                      IsItemClickEnabled="True" ItemClick="OnMovieClick">
                <ListView.ItemTemplate>
                    <DataTemplate x:DataType="models:MovieListItem">
                        <local:MovieRowControl Movie="{x:Bind}" HorizontalAlignment="Stretch"/>
                    </DataTemplate>
                </ListView.ItemTemplate>
            </ListView>

            <!-- Empty State -->
            <StackPanel Grid.Row="0" VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="12">
                <TextBlock Text="📭" FontSize="48" HorizontalAlignment="Center"/>
                <TextBlock x:Name="EmptyText" Text="No movies found with this filter" FontSize="14" Foreground="{ThemeResource MutedBrush}" HorizontalAlignment="Center"/>
            </StackPanel>

            <!-- Status Bar -->
            <Border Grid.Row="1" Background="{ThemeResource SidebarBrush}" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="0,1,0,0" Padding="24,12">
                <StackPanel Orientation="Horizontal" Spacing="12">
                    <TextBlock Text="Results:" FontSize="12" Foreground="{ThemeResource MutedBrush}" VerticalAlignment="Center"/>
                    <TextBlock x:Name="ResultsCountText" Text="0 movies" FontSize="12" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>
        </Grid>
    </Grid>
</Page>
