<UserControl
    x:Class="CineLibraryCS.Views.TvShowCard"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- No ToolTip: recycled cards orphan tooltips on scroll (see MovieCardControl). -->
    <Grid x:Name="CardRoot" Width="170" Height="300" RenderTransformOrigin="0.5,0.5">
        <Grid.RenderTransform>
            <TranslateTransform x:Name="CardLift" Y="0"/>
        </Grid.RenderTransform>
        <Border x:Name="CardBorder" Background="{ThemeResource CardBrush}" CornerRadius="12">
            <Border.Shadow><ThemeShadow/></Border.Shadow>
            <Grid>
                <!-- Poster -->
                <Image x:Name="PosterImage" Stretch="UniformToFill"/>
                <Grid x:Name="PosterPlaceholder">
                    <Grid.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="{ThemeResource PlaceholderTopColor}"/>
                            <GradientStop Offset="1" Color="{ThemeResource PlaceholderBottomColor}"/>
                        </LinearGradientBrush>
                    </Grid.Background>
                    <TextBlock Text="📺" FontSize="44" Opacity="0.85"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Grid>

                <!-- Favorite star -->
                <Border x:Name="FavBadge" Style="{StaticResource PosterBadgeStyle}"
                        VerticalAlignment="Top" HorizontalAlignment="Right"
                        Margin="8" Visibility="Collapsed">
                    <TextBlock Text="★" FontSize="13" Foreground="#F59E0B"/>
                </Border>

                <!-- Status badge -->
                <Border x:Name="StatusBadge" Background="#CC000000" CornerRadius="8"
                        VerticalAlignment="Top" HorizontalAlignment="Left"
                        Padding="6,2" Margin="6" Visibility="Collapsed">
                    <TextBlock x:Name="StatusText" FontSize="9" FontWeight="Bold" Foreground="White"/>
                </Border>

                <!-- Info strip -->
                <Border VerticalAlignment="Bottom" CornerRadius="0,0,12,12" Padding="10,8">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                            <GradientStop Offset="0" Color="#00000000"/>
                            <GradientStop Offset="0.35" Color="#99000000"/>
                            <GradientStop Offset="1" Color="#F2000000"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <StackPanel VerticalAlignment="Bottom" Spacing="5">
                        <TextBlock x:Name="TitleText" FontSize="13" FontWeight="Bold"
                                   Foreground="White" TextTrimming="CharacterEllipsis"
                                   MaxLines="2" TextWrapping="WrapWholeWords"/>
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock x:Name="MetaText" Grid.Column="0" FontSize="11" Foreground="#D8D8D8"/>
                            <TextBlock x:Name="ProgressText" Grid.Column="1" FontSize="11"
                                       FontWeight="SemiBold" Foreground="#A78BFA"/>
                        </Grid>
                        <!-- Watched progress bar -->
                        <Border Height="4" CornerRadius="2" Background="#40FFFFFF">
                            <Border x:Name="ProgressFill" Height="4" CornerRadius="2"
                                    HorizontalAlignment="Left"
                                    Background="{StaticResource BrandPurpleBrush}"/>
                        </Border>
                    </StackPanel>
                </Border>
            </Grid>
        </Border>
    </Grid>
</UserControl>
