<?xml version="1.0" encoding="utf-8"?>
<ContentDialog
    x:Class="CineLibraryCS.Views.KeyboardShortcutsDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Title="⌨️ Keyboard Shortcuts"
    PrimaryButtonText="Close"
    DefaultButton="Primary"
    Width="500"
    MaxHeight="600">

    <ScrollViewer VerticalScrollBarVisibility="Auto">
        <StackPanel Padding="20" Spacing="16">

            <!-- Navigation Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Navigation" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+F" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Focus search box" Foreground="{ThemeResource TextBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Ctrl+L" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Toggle sidebar" Foreground="{ThemeResource TextBrush}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Ctrl+Q" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Quit application" Foreground="{ThemeResource TextBrush}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="F5" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Refresh library" Foreground="{ThemeResource TextBrush}"/>
                </Grid>
            </StackPanel>

            <Border BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="0,1,0,0"/>

            <!-- Movie Actions Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Movie Actions" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Enter" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Open selected movie details" Foreground="{ThemeResource TextBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Delete" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Delete selected movie" Foreground="{ThemeResource TextBrush}"/>

                    <TextBlock Grid.Row="2" Grid.Column="0" Text="Space" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="2" Grid.Column="1" Text="Toggle favorite/watched" Foreground="{ThemeResource TextBrush}"/>

                    <TextBlock Grid.Row="3" Grid.Column="0" Text="W" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="3" Grid.Column="1" Text="Add to watchlist" Foreground="{ThemeResource TextBrush}"/>
                </Grid>
            </StackPanel>

            <Border BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="0,1,0,0"/>

            <!-- Theme Section -->
            <StackPanel Spacing="8">
                <TextBlock Text="Theme & Display" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                <Grid RowSpacing="8">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="120"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0" Text="Ctrl+B" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="0" Grid.Column="1" Text="Toggle light/dark theme" Foreground="{ThemeResource TextBrush}"/>

                    <TextBlock Grid.Row="1" Grid.Column="0" Text="Escape" FontFamily="Courier New" FontWeight="SemiBold" Foreground="{ThemeResource AccentBrush}"/>
                    <TextBlock Grid.Row="1" Grid.Column="1" Text="Close dialogs and menus" Foreground="{ThemeResource TextBrush}"/>
                </Grid>
            </StackPanel>
        </StackPanel>
    </ScrollViewer>
</ContentDialog>
