<?xml version="1.0" encoding="utf-8"?>
<Page
    x:Class="CineLibraryCS.Views.StatisticsPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    Background="{ThemeResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Top Bar -->
        <Grid Grid.Row="0" Padding="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <Button x:Name="BackToggleBtn" Grid.Column="0" Click="OnBackToggleClick"
                    Background="{ThemeResource InputBgBrush}" BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1" CornerRadius="8" Padding="8" Width="36" Height="36"
                    VerticalAlignment="Center" Margin="0,0,12,0" ToolTipService.ToolTip="Show sidebar" Visibility="Collapsed">
                <TextBlock Text="‹" FontSize="18" FontWeight="Bold" VerticalAlignment="Center" HorizontalAlignment="Center" Foreground="{ThemeResource TextBrush}"/>
            </Button>

            <TextBlock Grid.Column="1" Text="📊 Statistics" FontSize="18" FontWeight="Bold" 
                       Foreground="{ThemeResource TextBrush}" CharacterSpacing="100" VerticalAlignment="Center"/>

            <Button Grid.Column="2" Click="OnRefreshClick" Background="{ThemeResource InputBgBrush}" 
                    BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" CornerRadius="8" 
                    Padding="12,8" Content="🔄 Refresh" Foreground="{ThemeResource TextBrush}"/>
        </Grid>

        <!-- Content -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto">
            <StackPanel Padding="24" Spacing="20">

                <!-- Total Movies Card -->
                <Border CornerRadius="12" Background="{ThemeResource CardBg}" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="8">
                        <TextBlock Text="📚 Total Movies" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource MutedBrush}"/>
                        <TextBlock x:Name="TotalMoviesText" Text="0" FontSize="36" FontWeight="Bold" Foreground="{ThemeResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Total Runtime Card -->
                <Border CornerRadius="12" Background="{ThemeResource CardBg}" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="⏱️ Total Runtime" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource MutedBrush}"/>
                        <Grid ColumnSpacing="20">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="Hours" FontSize="11" Foreground="{ThemeResource MutedBrush}"/>
                                <TextBlock x:Name="RuntimeHoursText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AccentBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1">
                                <TextBlock Text="Days" FontSize="11" Foreground="{ThemeResource MutedBrush}"/>
                                <TextBlock x:Name="RuntimeDaysText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AccentBrush}"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="Years" FontSize="11" Foreground="{ThemeResource MutedBrush}"/>
                                <TextBlock x:Name="RuntimeYearsText" Text="0" FontSize="28" FontWeight="Bold" Foreground="{ThemeResource AccentBrush}"/>
                            </StackPanel>
                        </Grid>
                    </StackPanel>
                </Border>

                <!-- Watch Progress Card -->
                <Border CornerRadius="12" Background="{ThemeResource CardBg}" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="👁️ Watch Progress" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource MutedBrush}"/>
                        <TextBlock x:Name="WatchProgressText" Text="0 / 0 (0%)" FontSize="24" FontWeight="Bold" Foreground="{ThemeResource AccentBrush}"/>
                        <ProgressBar x:Name="WatchProgressBar" Value="0" Maximum="100" Height="8" CornerRadius="4" Background="{ThemeResource InputBgBrush}" Foreground="{ThemeResource AccentBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Movies by Decade -->
                <Border CornerRadius="12" Background="{ThemeResource CardBg}" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="📅 Movies by Decade" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource MutedBrush}"/>
                        <ListView x:Name="DecadeListView" SelectionMode="None" IsItemClickEnabled="False">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Margin="0,6" Padding="0,6" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="80"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="60"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Decade}" FontWeight="SemiBold" Foreground="{ThemeResource TextBrush}"/>
                                        <ProgressBar Grid.Column="1" Value="{Binding Percentage}" Maximum="100" Height="6" CornerRadius="3" Background="{ThemeResource InputBgBrush}" Foreground="{ThemeResource AccentBrush}"/>
                                        <TextBlock Grid.Column="2" Text="{Binding Count}" TextAlignment="Right" Foreground="{ThemeResource MutedBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Top Directors -->
                <Border CornerRadius="12" Background="{ThemeResource CardBg}" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="🎬 Top Directors" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource MutedBrush}"/>
                        <ListView x:Name="DirectorsListView" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="250">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Margin="0,4" Padding="0,4" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{ThemeResource TextBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Count}" TextAlignment="Right" Foreground="{ThemeResource MutedBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>

                <!-- Top Actors -->
                <Border CornerRadius="12" Background="{ThemeResource CardBg}" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1" Padding="20">
                    <StackPanel Spacing="12">
                        <TextBlock Text="👥 Top Actors" FontSize="14" FontWeight="SemiBold" Foreground="{ThemeResource MutedBrush}"/>
                        <ListView x:Name="ActorsListView" SelectionMode="None" IsItemClickEnabled="False" MaxHeight="250">
                            <ListView.ItemTemplate>
                                <DataTemplate>
                                    <Grid ColumnSpacing="12" Margin="0,4" Padding="0,4" BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="0,0,0,1">
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="50"/>
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Grid.Column="0" Text="{Binding Name}" Foreground="{ThemeResource TextBrush}"/>
                                        <TextBlock Grid.Column="1" Text="{Binding Count}" TextAlignment="Right" Foreground="{ThemeResource MutedBrush}"/>
                                    </Grid>
                                </DataTemplate>
                            </ListView.ItemTemplate>
                        </ListView>
                    </StackPanel>
                </Border>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
