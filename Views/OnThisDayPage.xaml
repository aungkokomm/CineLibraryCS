<Page
    x:Class="CineLibraryCS.Views.OnThisDayPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS.Views"
    xmlns:models="using:CineLibraryCS.Models"
    Background="{ThemeResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Header strip — back button + title + adaptive sub-line -->
        <Grid Grid.Row="0" Padding="24,8,24,12">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
            </Grid.ColumnDefinitions>
            <Button x:Name="BackBtn" Grid.Column="0" Click="OnBackClick"
                    Background="{ThemeResource InputBgBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}" BorderThickness="1"
                    CornerRadius="8" Padding="10,6" Height="36" Margin="0,0,12,0"
                    VerticalAlignment="Center">
                <StackPanel Orientation="Horizontal" Spacing="6">
                    <TextBlock Text="‹" FontSize="18" FontWeight="Bold"
                               Foreground="{ThemeResource TextBrush}"/>
                    <TextBlock Text="Back" FontSize="13" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}"/>
                </StackPanel>
            </Button>
            <StackPanel Grid.Column="1" Spacing="2" VerticalAlignment="Center">
                <TextBlock Text="📅  ON THIS DAY" FontSize="18" FontWeight="Bold"
                           Foreground="{ThemeResource TextBrush}" CharacterSpacing="100"/>
                <TextBlock x:Name="SubText" FontSize="12"
                           Foreground="{ThemeResource MutedBrush}"/>
            </StackPanel>
        </Grid>

        <!-- Scrollable body with two optional sections -->
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="0">
            <StackPanel Spacing="0">
                <!-- "You watched on this date" -->
                <StackPanel x:Name="WatchedSection" Visibility="Collapsed" Spacing="8" Margin="0,4,0,18">
                    <Grid Margin="24,4,24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🎞  YOU WATCHED ON THIS DATE"
                                   FontSize="12" FontWeight="SemiBold" CharacterSpacing="150"
                                   Opacity="0.85"
                                   Foreground="{StaticResource BrandPurpleBrush}"/>
                        <TextBlock x:Name="WatchedSub" Grid.Column="1" FontSize="11"
                                   Foreground="{ThemeResource MutedBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <ItemsRepeater x:Name="WatchedRepeater" Margin="24,4,24,8">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="150" MinItemHeight="280"
                                               MinColumnSpacing="12" MinRowSpacing="12"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:MovieListItem">
                                <local:MovieCardControl Movie="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- "Released on this date" -->
                <StackPanel x:Name="ReleasedSection" Visibility="Collapsed" Spacing="8" Margin="0,0,0,24">
                    <Grid Margin="24,4,24,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Text="🎬  RELEASED ON THIS DATE"
                                   FontSize="12" FontWeight="SemiBold" CharacterSpacing="150"
                                   Opacity="0.85"
                                   Foreground="{StaticResource BrandPurpleBrush}"/>
                        <TextBlock x:Name="ReleasedSub" Grid.Column="1" FontSize="11"
                                   Foreground="{ThemeResource MutedBrush}"
                                   VerticalAlignment="Center"/>
                    </Grid>
                    <ItemsRepeater x:Name="ReleasedRepeater" Margin="24,4,24,8">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout MinItemWidth="150" MinItemHeight="280"
                                               MinColumnSpacing="12" MinRowSpacing="12"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:MovieListItem">
                                <local:MovieCardControl Movie="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </StackPanel>

                <!-- Empty state — defensive; sidebar entry hides when no matches, so reaching here empty is unusual -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Margin="0,80,0,24" Spacing="8">
                    <TextBlock Text="📅" FontSize="48" HorizontalAlignment="Center" Opacity="0.7"/>
                    <TextBlock Text="Nothing tied to today"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}" HorizontalAlignment="Center"/>
                    <TextBlock Text="Check back tomorrow — On This Day surfaces movies you watched on this date in past years, plus films released on this date in past years."
                               FontSize="12" Foreground="{ThemeResource MutedBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap" MaxWidth="440"/>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Page>
