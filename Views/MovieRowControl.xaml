<UserControl
    x:Class="CineLibraryCS.Views.MovieRowControl"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <Border Background="Transparent" Padding="0,1"
            Tapped="OnTapped" DoubleTapped="OnDoubleTapped"
            PointerEntered="OnPointerEntered" PointerExited="OnPointerExited">
        <Border x:Name="RowBorder" Background="{ThemeResource CardBrush}"
                CornerRadius="8" Padding="12,10">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="48"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="80"/>
                    <ColumnDefinition Width="100"/>
                    <ColumnDefinition Width="80"/>
                </Grid.ColumnDefinitions>

                <!-- Thumbnail -->
                <Border Grid.Column="0" Width="44" Height="60" CornerRadius="4">
                    <Grid>
                        <Image x:Name="ThumbImage" Stretch="UniformToFill"/>
                        <TextBlock x:Name="ThumbPlaceholder" Text="🎬" FontSize="22"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Grid>
                </Border>

                <!-- Main info -->
                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="12,0">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <TextBlock x:Name="RowTitle" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextBrush}"
                                   TextTrimming="CharacterEllipsis"/>
                        <TextBlock x:Name="RowFav" Text="★" Foreground="#F59E0B"
                                   FontSize="13" VerticalAlignment="Center" Visibility="Collapsed"/>
                    </StackPanel>
                    <TextBlock x:Name="RowMeta" FontSize="12"
                               Foreground="{ThemeResource MutedBrush}" Margin="0,2,0,0"/>
                    <StackPanel Orientation="Horizontal" Spacing="4" Margin="0,3,0,0">
                        <Ellipse x:Name="DriveDot" Width="7" Height="7" VerticalAlignment="Center"/>
                        <TextBlock x:Name="DriveLabel" FontSize="11"
                                   Foreground="{ThemeResource MutedBrush}"/>
                    </StackPanel>
                </StackPanel>

                <!-- Rating -->
                <TextBlock Grid.Column="2" x:Name="RowRating"
                           Foreground="#F59E0B" FontSize="13"
                           VerticalAlignment="Center" HorizontalAlignment="Center"/>

                <!-- Status -->
                <Border Grid.Column="3" x:Name="RowStatusBadge"
                        CornerRadius="4" Padding="8,3"
                        VerticalAlignment="Center" HorizontalAlignment="Center">
                    <TextBlock x:Name="RowStatusText" FontSize="11" FontWeight="Bold"
                               Foreground="{ThemeResource TextBrush}"/>
                </Border>

                <!-- Actions -->
                <StackPanel Grid.Column="4" Orientation="Horizontal" Spacing="6"
                            VerticalAlignment="Center" HorizontalAlignment="Center">
                    <Button x:Name="WatchedBtn" Style="{StaticResource IconButtonStyle}"
                            Click="OnToggleWatched" ToolTipService.ToolTip="Toggle watched"
                            FontSize="15"/>
                    <Button x:Name="FavBtn" Style="{StaticResource IconButtonStyle}"
                            Click="OnToggleFav" ToolTipService.ToolTip="Toggle favorite"
                            FontSize="15"/>
                </StackPanel>
            </Grid>
        </Border>
    </Border>
</UserControl>
