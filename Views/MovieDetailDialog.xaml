<Window
    x:Class="CineLibraryCS.Views.MovieDetailDialog"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:models="using:CineLibraryCS.Models"
    Title="Movie Details">

    <Grid x:Name="RootGrid" Background="{ThemeResource SidebarBrush}">
        <Grid.RowDefinitions>
            <RowDefinition Height="36"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- Custom titlebar drag region -->
        <Grid x:Name="AppTitleBar" Grid.Row="0" Background="Transparent">
            <TextBlock x:Name="TitleBarText" Text="Movie Details"
                       FontSize="12" FontWeight="SemiBold"
                       Foreground="{ThemeResource TextBrush}"
                       VerticalAlignment="Center" Margin="14,0,0,0"/>
        </Grid>

        <!-- Scroll area + sticky action bar overlay (v2.3) -->
        <Grid Grid.Row="1">
            <ScrollViewer x:Name="ContentScroller" VerticalScrollBarVisibility="Auto"
                          HorizontalScrollBarVisibility="Disabled" Padding="24"
                          ViewChanged="OnContentScrolled">
            <StackPanel MaxWidth="1100" HorizontalAlignment="Stretch">

                <!-- Hero fanart (v2.3 — taller, layered gradient, vignette, IMDb/TMDb pills) -->
                <Border x:Name="HeroBorder" Height="340" CornerRadius="12"
                        Background="{ThemeResource HeroBgBrush}"
                        HorizontalAlignment="Stretch">
                    <Grid>
                        <Image x:Name="HeroImage" Stretch="UniformToFill"/>
                        <!-- Vertical gradient — strong on the bottom so titles stay readable -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="0,1">
                                    <GradientStop Offset="0"    Color="#33000000"/>
                                    <GradientStop Offset="0.55" Color="#22000000"/>
                                    <GradientStop Offset="1"    Color="#E6000000"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- Horizontal vignette — subtle edge darkening -->
                        <Border>
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0.5" EndPoint="1,0.5">
                                    <GradientStop Offset="0"    Color="#55000000"/>
                                    <GradientStop Offset="0.5"  Color="#00000000"/>
                                    <GradientStop Offset="1"    Color="#55000000"/>
                                </LinearGradientBrush>
                            </Border.Background>
                        </Border>
                        <!-- IMDb / TMDb badge pills, top-right -->
                        <StackPanel x:Name="ExternalLinksPanel" Orientation="Horizontal"
                                    Spacing="6" Margin="14"
                                    HorizontalAlignment="Right" VerticalAlignment="Top">
                            <Button x:Name="ImdbLinkBtn" Visibility="Collapsed"
                                    Click="OnOpenImdb"
                                    Background="#F5C518" Foreground="#000000"
                                    BorderThickness="0" CornerRadius="4"
                                    Padding="8,3" FontSize="11" FontWeight="Bold"
                                    Content="IMDb"/>
                            <Button x:Name="TmdbLinkBtn" Visibility="Collapsed"
                                    Click="OnOpenTmdb"
                                    Background="#01D277" Foreground="#000000"
                                    BorderThickness="0" CornerRadius="4"
                                    Padding="8,3" FontSize="11" FontWeight="Bold"
                                    Content="TMDb"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- Poster + Meta row -->
                <Grid Margin="0,-120,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <!-- Poster column: poster card + below-poster info card -->
                    <StackPanel Grid.Column="0" Margin="16,0,24,0" VerticalAlignment="Top"
                                Spacing="12">
                        <!-- Poster — drop shadow + thin border for depth -->
                        <Border Width="200" Height="290" CornerRadius="12"
                                BorderBrush="#33FFFFFF" BorderThickness="1"
                                Background="{ThemeResource PlaceholderBgBrush}">
                            <Border.Shadow>
                                <ThemeShadow/>
                            </Border.Shadow>
                            <Border.Translation>0,0,32</Border.Translation>
                            <Grid>
                                <TextBlock x:Name="PosterPlaceholder" Text="🎬" FontSize="56"
                                           HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                <Image x:Name="PosterImage" Stretch="UniformToFill"/>
                            </Grid>
                        </Border>

                    </StackPanel>

                    <!-- Meta -->
                    <StackPanel Grid.Column="1" Spacing="10" VerticalAlignment="Top"
                                Margin="0,140,0,0">
                        <TextBlock x:Name="DetailTitle" FontSize="34" FontWeight="Bold"
                                   Foreground="{ThemeResource TextBrush}"
                                   TextWrapping="Wrap" LineHeight="40"/>
                        <TextBlock x:Name="OriginalTitle" FontSize="14" FontStyle="Italic"
                                   Foreground="{ThemeResource MutedBrush}" Visibility="Collapsed"
                                   TextWrapping="Wrap"/>
                        <!-- Tagline with a thin colored accent bar -->
                        <Grid x:Name="TaglineWrap" Visibility="Collapsed" Margin="0,2,0,0">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="3"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <Border Background="{StaticResource BrandPurpleBrush}"
                                    CornerRadius="2" Margin="0,2,8,2"/>
                            <TextBlock x:Name="Tagline" Grid.Column="1"
                                       FontStyle="Italic" FontSize="14"
                                       Foreground="{StaticResource BrandPurpleBrush}"
                                       TextWrapping="Wrap"/>
                        </Grid>
                        <StackPanel x:Name="ChipsPanel" Orientation="Horizontal" Spacing="6" Margin="0,4,0,0"/>
                        <!-- Tech badges + ratings on the same row to save vertical space -->
                        <StackPanel Orientation="Horizontal" Spacing="16" Margin="0,4,0,0"
                                    VerticalAlignment="Center">
                            <ItemsControl x:Name="TechBadges" VerticalAlignment="Center">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" Spacing="4"/>
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                            </ItemsControl>
                            <StackPanel x:Name="RatingsPanel" Orientation="Horizontal" Spacing="18"
                                        VerticalAlignment="Center" Visibility="Collapsed"/>
                        </StackPanel>
                    </StackPanel>
                </Grid>

                <!-- Drive location -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,16,0,0">
                    <TextBlock Text="Located on:" FontSize="12"
                               Foreground="{ThemeResource MutedBrush}" VerticalAlignment="Center"/>
                    <Ellipse x:Name="DriveStatusDot" Width="8" Height="8" VerticalAlignment="Center"/>
                    <TextBlock x:Name="DriveText" FontSize="12"
                               Foreground="{ThemeResource TextBrush}" VerticalAlignment="Center"
                               TextWrapping="Wrap"/>
                </StackPanel>

                <!-- Actions -->
                <StackPanel Orientation="Horizontal" Spacing="8" Margin="0,12,0,0">
                    <Button x:Name="PlayBtn" Click="OnPlay"
                            Background="#A78BFA" Foreground="White"
                            BorderThickness="0" CornerRadius="8" Padding="16,8">
                        <TextBlock Text="▶ Play"/>
                    </Button>
                    <Button x:Name="FolderBtn" Content="📂 Open Folder" Click="OnOpenFolder"
                            Background="{ThemeResource CardBrush}"
                            Foreground="{ThemeResource TextBrush}"
                            BorderBrush="{ThemeResource BorderBrush}"
                            CornerRadius="8" Padding="12,8"/>
                    <Button x:Name="FavBtn" Click="OnToggleFav"
                            Background="{ThemeResource CardBrush}"
                            Foreground="{ThemeResource TextBrush}"
                            BorderBrush="{ThemeResource BorderBrush}"
                            CornerRadius="8" Padding="12,8"/>
                    <Button x:Name="WatchedBtn" Click="OnToggleWatched"
                            Background="{ThemeResource CardBrush}"
                            Foreground="{ThemeResource TextBrush}"
                            BorderBrush="{ThemeResource BorderBrush}"
                            CornerRadius="8" Padding="12,8"/>
                    <Button x:Name="WatchlistBtn" Click="OnToggleWatchlist"
                            Background="{ThemeResource CardBrush}"
                            Foreground="{ThemeResource TextBrush}"
                            BorderBrush="{ThemeResource BorderBrush}"
                            CornerRadius="8" Padding="12,8"/>
                    <Button x:Name="ListsBtn" Content="📑 Add to list"
                            Background="{ThemeResource CardBrush}"
                            Foreground="{ThemeResource TextBrush}"
                            BorderBrush="{ThemeResource BorderBrush}"
                            CornerRadius="8" Padding="12,8">
                        <Button.Flyout>
                            <MenuFlyout x:Name="ListsFlyout" Placement="Bottom" Opening="OnListsFlyoutOpening"/>
                        </Button.Flyout>
                    </Button>
                </StackPanel>

                <!-- v2.5 — Lists this movie is on. Each chip has a ✕ that
                     removes the movie from that list immediately (with Undo
                     in the toast). The whole row hides when there are none. -->
                <ItemsControl x:Name="ListChipsRepeater" Margin="0,10,0,0" Visibility="Collapsed">
                    <ItemsControl.ItemsPanel>
                        <ItemsPanelTemplate>
                            <StackPanel Orientation="Horizontal" Spacing="6"/>
                        </ItemsPanelTemplate>
                    </ItemsControl.ItemsPanel>
                </ItemsControl>

                <!-- File info panel (v2.2.2) — sits right under the action row -->
                <Border x:Name="FileInfoPanel" Visibility="Collapsed"
                        Margin="0,12,0,0" Padding="12,8"
                        Background="{ThemeResource CardBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <StackPanel Orientation="Horizontal" Spacing="24">
                        <StackPanel x:Name="FiRuntimeBlock" Visibility="Collapsed">
                            <TextBlock Text="RUNTIME" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiRuntime" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiReleaseBlock" Visibility="Collapsed">
                            <TextBlock Text="RELEASED" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiRelease" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiMpaaBlock" Visibility="Collapsed">
                            <TextBlock Text="RATED" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiMpaa" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiCountryBlock" Visibility="Collapsed">
                            <TextBlock Text="COUNTRY" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiCountry" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiSizeBlock" Visibility="Collapsed">
                            <TextBlock Text="FILE SIZE" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiSize" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiDurBlock" Visibility="Collapsed">
                            <TextBlock Text="DURATION" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiDur" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiContainerBlock" Visibility="Collapsed">
                            <TextBlock Text="CONTAINER" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiContainer" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiLangBlock" Visibility="Collapsed">
                            <TextBlock Text="AUDIO" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiLangs" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                        <StackPanel x:Name="FiSubsBlock" Visibility="Collapsed">
                            <TextBlock Text="SUBTITLES" FontSize="9" FontWeight="SemiBold"
                                       CharacterSpacing="150" Opacity="0.65"
                                       Foreground="{ThemeResource MutedBrush}"/>
                            <TextBlock x:Name="FiSubs" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"/>
                        </StackPanel>
                    </StackPanel>
                </Border>

                <!-- Plot — with section header + capped width for readability -->
                <Border x:Name="PlotDivider" Visibility="Collapsed"
                        Height="1" Background="{ThemeResource BorderBrush}"
                        Margin="0,24,0,0" Opacity="0.5"/>
                <StackPanel x:Name="PlotSection" Visibility="Collapsed" Margin="0,20,0,0" Spacing="8">
                    <TextBlock Text="PLOT" FontSize="10" FontWeight="SemiBold"
                               CharacterSpacing="150" Opacity="0.65"
                               Foreground="{ThemeResource MutedBrush}"/>
                    <TextBlock x:Name="PlotText" FontSize="14" Foreground="{ThemeResource TextBrush}"
                               TextWrapping="Wrap" LineHeight="22" MaxWidth="780"
                               HorizontalAlignment="Left"/>
                </StackPanel>

                <!-- Notes (v1.9) -->
                <Border Margin="0,20,0,0" Padding="14,12"
                        Background="{ThemeResource CardBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        BorderThickness="1" CornerRadius="8">
                    <StackPanel Spacing="8">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBlock Grid.Column="0" Text="📝 Notes"
                                       FontSize="14" FontWeight="SemiBold"
                                       Foreground="{ThemeResource TextBrush}"
                                       VerticalAlignment="Center"/>
                            <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="6">
                                <Button x:Name="NoteAddBtn" Click="OnNoteEditStart"
                                        Content="+ Add note" Visibility="Collapsed"
                                        Background="Transparent"
                                        Foreground="{ThemeResource MutedBrush}"
                                        BorderBrush="{ThemeResource BorderBrush}"
                                        CornerRadius="6" Padding="10,4" FontSize="12"/>
                                <Button x:Name="NoteEditBtn" Click="OnNoteEditStart"
                                        Content="Edit" Visibility="Collapsed"
                                        Background="Transparent"
                                        Foreground="{ThemeResource MutedBrush}"
                                        BorderBrush="{ThemeResource BorderBrush}"
                                        CornerRadius="6" Padding="10,4" FontSize="12"/>
                                <Button x:Name="NoteSaveBtn" Click="OnNoteSave"
                                        Content="Save" Visibility="Collapsed"
                                        Background="{StaticResource BrandPurpleBrush}"
                                        Foreground="#FFFFFF"
                                        BorderThickness="0"
                                        CornerRadius="6" Padding="10,4" FontSize="12"/>
                                <Button x:Name="NoteCancelBtn" Click="OnNoteCancel"
                                        Content="Cancel" Visibility="Collapsed"
                                        Background="Transparent"
                                        Foreground="{ThemeResource MutedBrush}"
                                        BorderBrush="{ThemeResource BorderBrush}"
                                        CornerRadius="6" Padding="10,4" FontSize="12"/>
                            </StackPanel>
                        </Grid>
                        <TextBlock x:Name="NoteText" Visibility="Collapsed"
                                   FontSize="13" Foreground="{ThemeResource TextBrush}"
                                   TextWrapping="Wrap" LineHeight="20"/>
                        <TextBox x:Name="NoteEditor" Visibility="Collapsed"
                                 AcceptsReturn="True" TextWrapping="Wrap"
                                 MinHeight="100" MaxHeight="240"
                                 PlaceholderText="What did you think of this film?"
                                 FontSize="13"/>
                        <TextBlock x:Name="NoteOfflineHint" Visibility="Collapsed"
                                   Text="Drive offline — note saved locally; will sync to the movie folder when reconnected."
                                   FontSize="11" Foreground="{ThemeResource MutedBrush}"
                                   FontStyle="Italic" TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- Subtle section divider before fields grid -->
                <Border Height="1" Background="{ThemeResource BorderBrush}"
                        Margin="0,24,0,0" Opacity="0.5"/>

                <!-- Fields grid -->
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" x:Name="GenresField" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Genres" FontSize="11" Foreground="{ThemeResource MutedBrush}"/>
                        <StackPanel x:Name="GenreLinks" Orientation="Horizontal" Spacing="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" x:Name="DirectorField" Visibility="Collapsed" Spacing="4">
                        <TextBlock Text="Director" FontSize="11" Foreground="{ThemeResource MutedBrush}"/>
                        <StackPanel x:Name="DirectorLinks" Orientation="Horizontal" Spacing="4"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Spacing="4">
                        <TextBlock x:Name="StudioLabel" Visibility="Collapsed"
                                   Text="Studio" FontSize="11" Foreground="{ThemeResource MutedBrush}"/>
                        <TextBlock x:Name="StudioText" Visibility="Collapsed"
                                   FontSize="13" Foreground="{ThemeResource TextBrush}"
                                   TextWrapping="Wrap"/>
                        <HyperlinkButton x:Name="StudioLink" Visibility="Collapsed"
                                         Padding="0" FontSize="13"/>
                    </StackPanel>
                </Grid>

                <!-- Divider above Cast -->
                <Border x:Name="CastDivider" Visibility="Collapsed"
                        Height="1" Background="{ThemeResource BorderBrush}"
                        Margin="0,24,0,0" Opacity="0.5"/>
                <!-- Cast — wraps to multiple rows, no side-scroll -->
                <StackPanel x:Name="CastSection" Margin="0,20,0,0" Visibility="Collapsed">
                    <TextBlock Text="Cast" FontSize="16" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}" Margin="0,0,0,10"/>
                        <ItemsRepeater x:Name="CastRepeater">
                            <ItemsRepeater.Layout>
                                <!-- Portrait 2:3 cards: 140 × 280 (image 140×210 + name/role) -->
                                <UniformGridLayout MinItemWidth="150" MinItemHeight="280"
                                                   MinColumnSpacing="14" MinRowSpacing="18"
                                                   ItemsStretch="None"
                                                   Orientation="Horizontal"/>
                            </ItemsRepeater.Layout>
                            <ItemsRepeater.ItemTemplate>
                                <DataTemplate x:DataType="models:Actor">
                                    <Button Width="140"
                                            Background="Transparent"
                                            BorderThickness="0" Padding="0"
                                            CornerRadius="10"
                                            HorizontalContentAlignment="Stretch"
                                            VerticalAlignment="Top"
                                            Tag="{x:Bind Name}"
                                            Click="OnActorClick">
                                        <StackPanel Spacing="8" HorizontalAlignment="Stretch">
                                            <!-- 2:3 portrait headshot (140 × 210, rounded) -->
                                            <Border Width="140" Height="210"
                                                    CornerRadius="10"
                                                    Background="{ThemeResource PlaceholderBgBrush}"
                                                    BorderBrush="{ThemeResource BorderBrush}"
                                                    BorderThickness="1">
                                                <Grid>
                                                    <!-- Initials sit behind the image and show
                                                         through when the thumbnail is missing
                                                         or fails to load. -->
                                                    <TextBlock Text="{x:Bind Initials}"
                                                               FontSize="34" FontWeight="SemiBold"
                                                               Foreground="{ThemeResource MutedBrush}"
                                                               HorizontalAlignment="Center"
                                                               VerticalAlignment="Center"/>
                                                    <Image Stretch="UniformToFill"
                                                           Source="{x:Bind ThumbBitmap, Mode=OneWay}"/>
                                                </Grid>
                                            </Border>
                                            <TextBlock Text="{x:Bind Name}"
                                                       FontSize="13" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextBrush}"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="WrapWholeWords"
                                                       MaxLines="2"/>
                                            <TextBlock Text="{x:Bind Role, TargetNullValue=''}"
                                                       FontSize="11"
                                                       Foreground="{ThemeResource MutedBrush}"
                                                       HorizontalAlignment="Center"
                                                       TextAlignment="Center"
                                                       TextWrapping="WrapWholeWords"
                                                       MaxLines="2"/>
                                        </StackPanel>
                                    </Button>
                                </DataTemplate>
                            </ItemsRepeater.ItemTemplate>
                        </ItemsRepeater>
                </StackPanel>

            </StackPanel>
        </ScrollViewer>

        <!-- Sticky action bar (v2.3) — appears once you scroll past the hero -->
        <Border x:Name="StickyBar" Visibility="Collapsed"
                Background="{ThemeResource SidebarBrush}"
                BorderBrush="{ThemeResource BorderBrush}"
                BorderThickness="0,0,0,1"
                Height="52" VerticalAlignment="Top" Opacity="0.96">
            <Grid Padding="20,0">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <TextBlock x:Name="StickyTitle" Grid.Column="0"
                           VerticalAlignment="Center"
                           FontSize="14" FontWeight="SemiBold"
                           Foreground="{ThemeResource TextBrush}"
                           TextTrimming="CharacterEllipsis"/>
                <StackPanel Grid.Column="1" Orientation="Horizontal" Spacing="8" VerticalAlignment="Center">
                    <Button x:Name="StickyPlayBtn" Click="OnPlay"
                            Background="#A78BFA" Foreground="White"
                            BorderThickness="0" CornerRadius="6" Padding="14,5">
                        <TextBlock Text="▶ Play"/>
                    </Button>
                    <Button Click="OnStickyClose"
                            Background="Transparent"
                            Foreground="{ThemeResource MutedBrush}"
                            BorderThickness="0" CornerRadius="6" Padding="10,5"
                            Content="✕"/>
                </StackPanel>
            </Grid>
        </Border>
        </Grid>
    </Grid>
</Window>
