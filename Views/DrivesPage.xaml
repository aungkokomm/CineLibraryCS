<Page
    x:Class="CineLibraryCS.Views.DrivesPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS.Views"
    xmlns:models="using:CineLibraryCS.Models"
    Background="{ThemeResource BgBrush}">

    <Grid Padding="24,8,24,24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Border Grid.Row="0" Height="0"/>

        <!-- Drive cards area -->
        <ScrollViewer Grid.Row="1">
            <StackPanel Spacing="16">

                <!-- Page header -->
                <Grid Margin="0,0,0,2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>

                    <TextBlock Grid.Row="0" Grid.Column="0"
                               Text="Drives" FontSize="24" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}"
                               VerticalAlignment="Center"/>

                    <StackPanel Grid.Row="0" Grid.Column="1" Grid.RowSpan="2"
                                Orientation="Horizontal" Spacing="8" VerticalAlignment="Top">
                        <Button x:Name="RefreshChangesBtn" Click="OnRefreshChanges"
                                Background="Transparent"
                                Foreground="{ThemeResource TextBrush}"
                                BorderBrush="{ThemeResource BorderBrush}"
                                BorderThickness="1"
                                CornerRadius="8" Padding="12,8"
                                ToolTipService.ToolTip="Rescan all connected drives for new or changed files">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE72C;" FontSize="14"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          VerticalAlignment="Center"/>
                                <TextBlock Text="Refresh changes" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <Button Click="OnAddDrive"
                                Background="{StaticResource BrandPurpleBrush}" Foreground="White"
                                BorderThickness="0" CornerRadius="8" Padding="14,8">
                            <StackPanel Orientation="Horizontal" Spacing="6">
                                <FontIcon Glyph="&#xE710;" FontSize="13"
                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                          Foreground="White" VerticalAlignment="Center"/>
                                <TextBlock Text="Add Drive" VerticalAlignment="Center" FontWeight="SemiBold"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>

                    <TextBlock Grid.Row="1" Grid.Column="0"
                               Text="External drives that hold your movies. Identified by hardware ID, so changing drive letters won't break anything."
                               Foreground="{ThemeResource MutedBrush}" FontSize="13"
                               TextWrapping="Wrap" MaxWidth="720"
                               HorizontalAlignment="Left"
                               Margin="0,4,16,0"/>
                </Grid>

                <!-- Empty state -->
                <Border x:Name="EmptyState" Visibility="Collapsed"
                        Background="{ThemeResource CardBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                        CornerRadius="12" Padding="28" Margin="0,8,0,0">
                    <StackPanel HorizontalAlignment="Center" Spacing="6">
                        <FontIcon Glyph="&#xEDA2;" FontSize="28"
                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                  Foreground="{ThemeResource MutedBrush}"/>
                        <TextBlock Text="No drives yet" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{ThemeResource TextBrush}" HorizontalAlignment="Center"/>
                        <TextBlock Text="Click + Add Drive to get started."
                                   Foreground="{ThemeResource MutedBrush}" FontSize="13"
                                   HorizontalAlignment="Center"/>
                    </StackPanel>
                </Border>

                <!-- Drive cards -->
                <ItemsRepeater x:Name="DrivesRepeater">
                    <ItemsRepeater.Layout>
                        <StackLayout Orientation="Vertical" Spacing="12"/>
                    </ItemsRepeater.Layout>
                    <ItemsRepeater.ItemTemplate>
                        <DataTemplate x:DataType="models:DriveInfo">
                            <Border Background="{ThemeResource CardBrush}"
                                    BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                                    CornerRadius="12" Padding="16,14"
                                    PointerEntered="OnCardPointerEntered"
                                    PointerExited="OnCardPointerExited">
                                <StackPanel Spacing="10">

                                    <!-- Header row: icon · name/status · counts · primary · overflow -->
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="*"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                            <ColumnDefinition Width="Auto"/>
                                        </Grid.ColumnDefinitions>

                                        <!-- Disk icon tile -->
                                        <Border Grid.Column="0" Width="34" Height="34"
                                                Background="{StaticResource BrandPurpleBrush}"
                                                CornerRadius="8" VerticalAlignment="Center">
                                            <FontIcon Glyph="&#xEDA2;" FontSize="16"
                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                      Foreground="White"
                                                      HorizontalAlignment="Center" VerticalAlignment="Center"/>
                                        </Border>

                                        <!-- Name + status -->
                                        <StackPanel Grid.Column="1" Margin="12,0,12,0"
                                                    VerticalAlignment="Center" Spacing="2">
                                            <TextBlock Text="{x:Bind Label}"
                                                       FontSize="16" FontWeight="SemiBold"
                                                       Foreground="{ThemeResource TextBrush}"
                                                       TextTrimming="CharacterEllipsis"/>
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <Ellipse Width="8" Height="8" VerticalAlignment="Center">
                                                    <Ellipse.Fill>
                                                        <SolidColorBrush Color="{x:Bind IsConnected, Converter={StaticResource BoolToColorConverter}}"/>
                                                    </Ellipse.Fill>
                                                </Ellipse>
                                                <TextBlock Text="{x:Bind NotConnectedText}"
                                                           FontSize="12" Foreground="{ThemeResource MutedBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </StackPanel>

                                        <!-- Count chips (tinted washes for identity + contrast) -->
                                        <StackPanel Grid.Column="2" Orientation="Horizontal" Spacing="6"
                                                    VerticalAlignment="Center" Margin="0,0,10,0">
                                            <Border Background="#26F59E0B"
                                                    CornerRadius="8" Padding="10,5">
                                                <TextBlock Text="{x:Bind MovieCountText}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource BrandGoldBrush}"/>
                                            </Border>
                                            <Border Background="#26A78BFA"
                                                    CornerRadius="8" Padding="10,5"
                                                    Visibility="{x:Bind TvShowVisibility}">
                                                <TextBlock Text="{x:Bind TvShowCountText}"
                                                           FontSize="12" FontWeight="SemiBold"
                                                           Foreground="{StaticResource BrandPurpleBrush}"/>
                                            </Border>
                                        </StackPanel>

                                        <!-- Primary action: Update Database -->
                                        <Button Grid.Column="3"
                                                Tag="{x:Bind VolumeSerial}"
                                                Click="OnUpdateDatabase"
                                                IsEnabled="{x:Bind IsConnected}"
                                                Background="{StaticResource BrandPurpleBrush}"
                                                Foreground="White"
                                                BorderThickness="0"
                                                CornerRadius="8" Padding="12,7"
                                                FontWeight="SemiBold"
                                                VerticalAlignment="Center"
                                                ToolTipService.ToolTip="Rescan this drive's folders for new or changed movies">
                                            <StackPanel Orientation="Horizontal" Spacing="6">
                                                <FontIcon Glyph="&#xE72C;" FontSize="13"
                                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                          Foreground="White"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="Update" VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Button>

                                        <!-- Overflow menu: secondary actions -->
                                        <Button Grid.Column="4"
                                                Background="Transparent" BorderThickness="0"
                                                Foreground="{ThemeResource MutedBrush}"
                                                CornerRadius="8" Padding="9,7" Margin="6,0,0,0"
                                                MinWidth="0" VerticalAlignment="Center"
                                                AutomationProperties.Name="More drive actions"
                                                ToolTipService.ToolTip="More actions">
                                            <FontIcon Glyph="&#xE712;" FontSize="16"
                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                            <Button.Flyout>
                                                <MenuFlyout Placement="BottomEdgeAlignedRight">
                                                    <MenuFlyoutItem Text="Browse movies"
                                                                    Tag="{x:Bind VolumeSerial}"
                                                                    Click="OnBrowseDrive">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE8DA;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Rename drive"
                                                                    Tag="{x:Bind VolumeSerial}"
                                                                    Click="OnRenameDrive">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE70F;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutItem Text="Sync state to drive"
                                                                    Tag="{x:Bind VolumeSerial}"
                                                                    Click="OnSyncStateToDrive"
                                                                    IsEnabled="{x:Bind IsConnected}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE895;" FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                    <MenuFlyoutSeparator/>
                                                    <MenuFlyoutItem Text="Remove drive"
                                                                    Tag="{x:Bind VolumeSerial}"
                                                                    Click="OnRemoveDrive"
                                                                    Foreground="{StaticResource AccentRedBrush}">
                                                        <MenuFlyoutItem.Icon>
                                                            <FontIcon Glyph="&#xE74D;"
                                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                      Foreground="{StaticResource AccentRedBrush}"/>
                                                        </MenuFlyoutItem.Icon>
                                                    </MenuFlyoutItem>
                                                </MenuFlyout>
                                            </Button.Flyout>
                                        </Button>
                                    </Grid>

                                    <!-- Missing-movies warning (Fluent InfoBar) -->
                                    <InfoBar Severity="Warning"
                                             IsOpen="{x:Bind HasMissing}"
                                             IsClosable="False"
                                             Message="{x:Bind MissingInfoText}">
                                        <InfoBar.ActionButton>
                                            <Button Content="{x:Bind MissingButtonText}"
                                                    Tag="{x:Bind VolumeSerial}"
                                                    Click="OnCleanupMissing"/>
                                        </InfoBar.ActionButton>
                                    </InfoBar>

                                    <!-- Hairline divider between actions and folder management -->
                                    <Border Height="1" Background="{ThemeResource BorderBrush}"
                                            Opacity="0.55" Margin="0,2,0,0"/>

                                    <!-- Folders (collapsible, flat chrome — no nested box) -->
                                    <Expander Visibility="{x:Bind FoldersVisibility}"
                                              HorizontalAlignment="Stretch"
                                              HorizontalContentAlignment="Stretch"
                                              Background="Transparent"
                                              BorderThickness="0"
                                              CornerRadius="0"
                                              Padding="0,0,0,4"
                                              Margin="0,-2,0,-2">
                                        <Expander.Resources>
                                            <SolidColorBrush x:Key="ExpanderHeaderBackground" Color="Transparent"/>
                                            <SolidColorBrush x:Key="ExpanderHeaderBorderBrush" Color="Transparent"/>
                                            <Thickness x:Key="ExpanderHeaderBorderThickness">0</Thickness>
                                            <SolidColorBrush x:Key="ExpanderContentBackground" Color="Transparent"/>
                                            <SolidColorBrush x:Key="ExpanderContentBorderBrush" Color="Transparent"/>
                                            <Thickness x:Key="ExpanderContentBorderThickness">0</Thickness>
                                        </Expander.Resources>
                                        <Expander.Header>
                                            <StackPanel Orientation="Horizontal" Spacing="8" Padding="0,4">
                                                <FontIcon Glyph="&#xE8B7;" FontSize="14"
                                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                          Foreground="{ThemeResource MutedBrush}"
                                                          VerticalAlignment="Center"/>
                                                <TextBlock Text="{x:Bind FolderCountText}"
                                                           FontSize="13"
                                                           Foreground="{ThemeResource TextBrush}"
                                                           VerticalAlignment="Center"/>
                                            </StackPanel>
                                        </Expander.Header>
                                        <ItemsRepeater ItemsSource="{x:Bind Folders}" Margin="0,8,0,0">
                                            <ItemsRepeater.Layout>
                                                <UniformGridLayout MinItemWidth="190"
                                                                   MinColumnSpacing="8" MinRowSpacing="8"
                                                                   ItemsStretch="Fill"/>
                                            </ItemsRepeater.Layout>
                                            <ItemsRepeater.ItemTemplate>
                                                <DataTemplate x:DataType="models:DriveRoot">
                                                    <Border Background="{ThemeResource ChipBrush}"
                                                            CornerRadius="8" Padding="10,8">
                                                        <Grid Background="Transparent"
                                                              PointerEntered="OnFolderPointerEntered"
                                                              PointerExited="OnFolderPointerExited">
                                                            <Grid.ColumnDefinitions>
                                                                <ColumnDefinition Width="Auto"/>
                                                                <ColumnDefinition Width="*"/>
                                                                <ColumnDefinition Width="Auto"/>
                                                            </Grid.ColumnDefinitions>
                                                            <FontIcon Grid.Column="0" Glyph="&#xE8B7;" FontSize="14"
                                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                                      Foreground="{StaticResource BrandPurpleBrush}"
                                                                      VerticalAlignment="Center" Margin="0,0,8,0"/>
                                                            <TextBlock Grid.Column="1" Text="{x:Bind DisplayName}"
                                                                       FontSize="13"
                                                                       Foreground="{ThemeResource TextBrush}"
                                                                       VerticalAlignment="Center"
                                                                       TextTrimming="CharacterEllipsis"
                                                                       ToolTipService.ToolTip="{x:Bind DisplayName}"/>
                                                            <Button Grid.Column="2"
                                                                    Tag="{x:Bind}"
                                                                    Click="OnRemoveFolder"
                                                                    Background="Transparent"
                                                                    BorderThickness="0"
                                                                    Foreground="{StaticResource AccentRedBrush}"
                                                                    Padding="4,0" MinWidth="0" MinHeight="0"
                                                                    Opacity="0"
                                                                    VerticalAlignment="Center"
                                                                    AutomationProperties.Name="Remove folder"
                                                                    ToolTipService.ToolTip="Remove folder and its movies">
                                                                <FontIcon Glyph="&#xE711;" FontSize="11"
                                                                          FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                                                            </Button>
                                                        </Grid>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsRepeater.ItemTemplate>
                                        </ItemsRepeater>
                                    </Expander>

                                    <!-- Add folder (subtle inline link) -->
                                    <Button Tag="{x:Bind VolumeSerial}"
                                            Click="OnAddFolder"
                                            Background="Transparent"
                                            BorderThickness="0"
                                            CornerRadius="6" Padding="6,4"
                                            Margin="-6,0,0,0"
                                            HorizontalAlignment="Left"
                                            Foreground="{StaticResource BrandPurpleBrush}"
                                            FontSize="13" FontWeight="SemiBold">
                                        <StackPanel Orientation="Horizontal" Spacing="6">
                                            <FontIcon Glyph="&#xE710;" FontSize="12"
                                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                                                      Foreground="{StaticResource BrandPurpleBrush}"
                                                      VerticalAlignment="Center"/>
                                            <TextBlock Text="Add folder" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Button>
                                </StackPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsRepeater.ItemTemplate>
                </ItemsRepeater>
            </StackPanel>
        </ScrollViewer>

        <!-- Scan progress overlay -->
        <Grid x:Name="ScanOverlay" Grid.Row="0" Grid.RowSpan="2"
              Background="{ThemeResource OverlayBrush}" Visibility="Collapsed">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center" Spacing="16">
                <ProgressRing Width="48" Height="48"
                              Foreground="{StaticResource BrandPurpleBrush}" IsActive="True"/>
                <TextBlock x:Name="ScanStatusText" Text="Scanning…" FontSize="16"
                           Foreground="{ThemeResource TextBrush}" HorizontalAlignment="Center"/>
                <TextBlock x:Name="ScanDetailText" FontSize="13"
                           Foreground="{StaticResource BrandPurpleBrush}"
                           HorizontalAlignment="Center" TextWrapping="Wrap"
                           MaxWidth="400" TextAlignment="Center"/>
                <Button Content="Cancel" Click="OnCancelScan"
                        Background="{ThemeResource CardBrush}"
                        Foreground="{ThemeResource TextBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                        CornerRadius="8"
                        Padding="20,8" HorizontalAlignment="Center"/>
            </StackPanel>
        </Grid>
    </Grid>
</Page>
