<Page
    x:Class="CineLibraryCS.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS.Views"
    xmlns:models="using:CineLibraryCS.Models"
    Background="{ThemeResource BgBrush}">

    <Page.Resources>
        <!-- Active (checked) toolbar toggles use the brand accent consistently
             instead of the default system-accent fill, so grid/list/density all
             read the same. -->
        <SolidColorBrush x:Key="ToggleButtonBackgroundChecked" Color="#A78BFA"/>
        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPointerOver" Color="#B49BFB"/>
        <SolidColorBrush x:Key="ToggleButtonBackgroundCheckedPressed" Color="#9B7BF5"/>
        <SolidColorBrush x:Key="ToggleButtonForegroundChecked" Color="White"/>
        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPointerOver" Color="White"/>
        <SolidColorBrush x:Key="ToggleButtonForegroundCheckedPressed" Color="White"/>
        <SolidColorBrush x:Key="ToggleButtonBorderBrushChecked" Color="Transparent"/>
        <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPointerOver" Color="Transparent"/>
        <SolidColorBrush x:Key="ToggleButtonBorderBrushCheckedPressed" Color="Transparent"/>
    </Page.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOP BAR ═══ -->
        <Grid Grid.Row="0" Padding="24,2,24,6">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- v2.7 — "back to Browse" button. Appears only when the
                 library view was drilled into from a Browse banner (By
                 Genre / Decade / Rating / Studio) or Collections; returns
                 to that page. Hidden for All Movies / Favorites / etc. -->
            <Button x:Name="BackToggleBtn"
                    Grid.Column="0"
                    Click="OnBrowseBackClick"
                    Background="{ThemeResource InputBgBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="10,6"
                    Height="36"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    Visibility="Collapsed">
                <StackPanel Orientation="Horizontal" Spacing="6" VerticalAlignment="Center">
                    <TextBlock Text="‹" FontSize="18" FontWeight="Bold"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextBrush}"/>
                    <TextBlock x:Name="BackLabel" Text="Back" FontSize="13" FontWeight="SemiBold"
                               VerticalAlignment="Center"
                               Foreground="{ThemeResource TextBrush}"/>
                </StackPanel>
            </Button>

            <TextBlock x:Name="PageTitleText" Grid.Column="1" Text="All movies"
                       FontSize="24" FontWeight="SemiBold" Foreground="{ThemeResource TextBrush}"
                       VerticalAlignment="Center"/>

            <!-- v3.2 — in-page search moved to the global title-bar search.
                 This box is kept (collapsed) as the page's internal engine so
                 existing focus/clear wiring keeps working. -->
            <Grid Grid.Column="2" Margin="20,0" ColumnSpacing="8" Visibility="Collapsed">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <!-- v3.1 — search scope: narrow what the box matches. -->
                <ComboBox Grid.Column="0" x:Name="ScopeCombo"
                          SelectionChanged="OnScopeChanged"
                          SelectedIndex="0"
                          MinWidth="96" Height="36"
                          VerticalAlignment="Center"
                          CornerRadius="8"
                          Background="{ThemeResource InputBgBrush}"
                          Foreground="{ThemeResource TextBrush}"
                          BorderBrush="{ThemeResource InputBorderBrush}"
                          ToolTipService.ToolTip="What the search matches">
                    <ComboBoxItem Tag="all"   Content="All"/>
                    <ComboBoxItem Tag="title" Content="Title"/>
                    <ComboBoxItem Tag="cast"  Content="Cast &amp; crew"/>
                </ComboBox>
                <AutoSuggestBox Grid.Column="1"
                                x:Name="SearchBox"
                                PlaceholderText="Search title, actor, director…"
                                QueryIcon="Find"
                                TextChanged="OnSearchChanged"
                                GotFocus="OnSearchBoxFocus"
                                LostFocus="OnSearchBoxBlur"
                                CornerRadius="8"
                                Background="{ThemeResource InputBgBrush}"
                                BorderBrush="{ThemeResource InputBorderBrush}"
                                Foreground="{ThemeResource TextBrush}"/>
                <Border x:Name="SearchEscHint" Grid.Column="2" Visibility="Collapsed"
                        Background="{ThemeResource ChipBrush}"
                        BorderBrush="{ThemeResource BorderBrush}" BorderThickness="1"
                        CornerRadius="4" Padding="6,2" Margin="6,0,0,0"
                        VerticalAlignment="Center"
                        IsHitTestVisible="False">
                    <TextBlock Text="Esc" FontSize="10" FontWeight="SemiBold"
                               Foreground="{ThemeResource MutedBrush}"
                               CharacterSpacing="50"/>
                </Border>
            </Grid>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                <ComboBox x:Name="SortCombo"
                          SelectionChanged="OnSortChanged"
                          Background="{ThemeResource InputBgBrush}"
                          Foreground="{ThemeResource TextBrush}"
                          BorderBrush="{ThemeResource InputBorderBrush}"
                          MinWidth="140"
                          Height="36"
                          CornerRadius="8"
                          VerticalAlignment="Center">
                    <ComboBoxItem Tag="title:asc"      Content="Title ↑"/>
                    <ComboBoxItem Tag="title:desc"     Content="Title ↓"/>
                    <ComboBoxItem Tag="year:desc"      Content="Year ↓"/>
                    <ComboBoxItem Tag="year:asc"       Content="Year ↑"/>
                    <ComboBoxItem Tag="rating:desc"    Content="Rating ↓"/>
                    <ComboBoxItem Tag="rating:asc"     Content="Rating ↑"/>
                    <ComboBoxItem Tag="runtime:desc"   Content="Runtime ↓"/>
                    <ComboBoxItem Tag="runtime:asc"    Content="Runtime ↑"/>
                    <ComboBoxItem Tag="date_added:desc" Content="Date Added ↓"/>
                    <ComboBoxItem Tag="date_added:asc"  Content="Date Added ↑"/>
                    <ComboBoxItem Tag="last_played:desc" Content="Last Watched ↓"/>
                    <ComboBoxItem Tag="last_played:asc"  Content="Last Watched ↑"/>
                </ComboBox>

                <!-- v2.9 — Surprise Me 🎲: filter-aware random pick. Honours
                     whatever is currently filtered/searched/listed, so you
                     can "random pick from current view". The existing
                     sidebar 'Surprise me' stays as the unfiltered version. -->
                <Button x:Name="SurpriseMeBtn" Click="OnSurpriseMeClick"
                        Background="{ThemeResource InputBgBrush}"
                        Foreground="{ThemeResource TextBrush}"
                        BorderBrush="{ThemeResource InputBorderBrush}"
                        CornerRadius="8"
                        Padding="10,8"
                        Height="36" Width="36"
                        VerticalAlignment="Center"
                        AutomationProperties.Name="Surprise me"
                        ToolTipService.ToolTip="Surprise me — random pick from current view">
                    <FontIcon Glyph="&#xE8B1;" FontSize="15"
                              FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"
                              VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </Button>

                <SplitButton Content="Export" Click="OnExportCsvDefault"
                             Background="{ThemeResource InputBgBrush}"
                             Foreground="{ThemeResource TextBrush}"
                             BorderBrush="{ThemeResource InputBorderBrush}"
                             CornerRadius="8"
                             Padding="16,8"
                             Height="36"
                             VerticalAlignment="Center">
                    <SplitButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Export as CSV"  Click="OnExportCsv"/>
                            <MenuFlyoutItem Text="Export as HTML" Click="OnExportHtml"/>
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>

                <!-- View mode — segmented (grid / list) -->
                <Border Background="{ThemeResource InputBgBrush}"
                        BorderBrush="{ThemeResource InputBorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Height="36" VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="GridViewToggle" IsChecked="True"
                                      Click="OnViewGrid"
                                      AutomationProperties.Name="Grid view"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="0" Height="36" Width="36"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      ToolTipService.ToolTip="Grid view">
                            <FontIcon Glyph="&#xE8A9;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                        </ToggleButton>
                        <ToggleButton x:Name="ListViewToggle"
                                      Click="OnViewList"
                                      AutomationProperties.Name="List view"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="0" Height="36" Width="36"
                                      HorizontalContentAlignment="Center"
                                      VerticalContentAlignment="Center"
                                      ToolTipService.ToolTip="List view">
                            <FontIcon Glyph="&#xE8FD;" FontSize="16"
                                      FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>

                <!-- Density picker: S / M / L / XL (like Windows Explorer) -->
                <Border Background="{ThemeResource InputBgBrush}"
                        BorderBrush="{ThemeResource InputBorderBrush}"
                        BorderThickness="1" CornerRadius="8"
                        Height="36"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="DensityS" Click="OnDensityClick" Tag="S"
                                      AutomationProperties.Name="Small posters"
                                      ToolTipService.ToolTip="Small posters"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center">
                            <TextBlock Text="S" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                        <ToggleButton x:Name="DensityM" Click="OnDensityClick" Tag="M" IsChecked="True"
                                      AutomationProperties.Name="Medium posters"
                                      ToolTipService.ToolTip="Medium posters"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center">
                            <TextBlock Text="M" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                        <ToggleButton x:Name="DensityL" Click="OnDensityClick" Tag="L"
                                      AutomationProperties.Name="Large posters"
                                      ToolTipService.ToolTip="Large posters"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center">
                            <TextBlock Text="L" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                        <ToggleButton x:Name="DensityXL" Click="OnDensityClick" Tag="XL"
                                      AutomationProperties.Name="Extra large posters"
                                      ToolTipService.ToolTip="Extra large posters"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center">
                            <TextBlock Text="XL" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ═══ FILTER BAR ═══ -->
        <StackPanel Grid.Row="1" Padding="24,0,24,8" Spacing="6">
            <StackPanel Orientation="Horizontal" Spacing="8">
                <TextBlock x:Name="MovieCountText" Text="0 movies"
                           Foreground="{ThemeResource MutedBrush}" FontSize="13"
                           VerticalAlignment="Center" Margin="0,0,12,0"/>
                <Button x:Name="FilterAll"      Content="All"       Tag="all"
                        Style="{StaticResource PillButtonActiveStyle}" Click="OnWatchedFilter"/>
                <Button x:Name="FilterUnwatched" Content="Unwatched" Tag="unwatched"
                        Style="{StaticResource PillButtonStyle}"       Click="OnWatchedFilter"/>
                <Button x:Name="FilterWatched"  Content="Watched"   Tag="watched"
                        Style="{StaticResource PillButtonStyle}"       Click="OnWatchedFilter"/>
                <Button x:Name="ClearFiltersBtn" Content="✕ Clear filters"
                        Click="OnClearFilters" Visibility="Collapsed"
                        Style="{StaticResource PillButtonStyle}"
                        Margin="12,0,0,0"/>
            </StackPanel>
            <!-- v2.6 — Active filter chips. Each one removes itself when
                 clicked, so the user can drop a single filter without
                 hunting through menus. -->
            <ItemsControl x:Name="ActiveFilterChips" Visibility="Collapsed">
                <ItemsControl.ItemsPanel>
                    <ItemsPanelTemplate>
                        <StackPanel Orientation="Horizontal" Spacing="6"/>
                    </ItemsPanelTemplate>
                </ItemsControl.ItemsPanel>
            </ItemsControl>
        </StackPanel>

        <!-- ═══ MOVIE GRID / LIST ═══ -->
        <ScrollViewer Grid.Row="2" x:Name="MainScroller"
                      VerticalScrollBarVisibility="Auto"
                      ViewChanged="OnScrollChanged">
          <StackPanel>
            <!-- v2.9 — TV shows matching the current search query.
                 Sits at the very top of the page when the user types
                 something the search picks up across both movies and
                 shows. Hidden when search is empty. -->
            <StackPanel x:Name="ShowsInSearchSection" Visibility="Collapsed" Spacing="8" Margin="0,0,0,8">
                <TextBlock x:Name="ShowsInSearchHeader" Text="TV SHOWS MATCHING"
                           Margin="24,4,24,0"
                           FontSize="12" FontWeight="SemiBold" CharacterSpacing="150"
                           Opacity="0.75"
                           Foreground="{ThemeResource MutedBrush}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled"
                              Height="312" Padding="24,0,24,0">
                    <ItemsRepeater x:Name="ShowsInSearchRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="14"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TvShowListItem">
                                <local:TvShowCard Show="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </StackPanel>

            <!-- v2.8.2 — when viewing a user list that also contains TV
                 shows, show them as a row at the top (lists are independent
                 buckets that hold both movies and shows). -->
            <StackPanel x:Name="ShowsInListSection" Visibility="Collapsed" Spacing="8" Margin="0,0,0,8">
                <TextBlock Text="TV SHOWS IN THIS LIST" Margin="24,4,24,0"
                           FontSize="12" FontWeight="SemiBold" CharacterSpacing="150"
                           Opacity="0.7" Foreground="{ThemeResource MutedBrush}"/>
                <ScrollViewer HorizontalScrollBarVisibility="Auto"
                              VerticalScrollBarVisibility="Disabled"
                              HorizontalScrollMode="Enabled" VerticalScrollMode="Disabled"
                              Height="312" Padding="24,0,24,0">
                    <ItemsRepeater x:Name="ShowsInListRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Horizontal" Spacing="14"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:TvShowListItem">
                                <local:TvShowCard Show="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </ScrollViewer>
            </StackPanel>

            <Grid>
                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="10" Margin="24,80,24,24" MaxWidth="440">
                    <TextBlock x:Name="EmptyIcon" Text="🎬" FontSize="56"
                               HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock x:Name="EmptyTitle" Text="No movies match your filters"
                               FontSize="16" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                    <TextBlock x:Name="EmptyStateHint"
                               Text="Try clearing the search or choosing 'All' watched filter."
                               FontSize="13" Foreground="{ThemeResource MutedBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"
                               TextWrapping="Wrap"/>
                    <Button x:Name="EmptyCtaBtn" Visibility="Collapsed"
                            Click="OnEmptyCtaClick"
                            HorizontalAlignment="Center"
                            Margin="0,8,0,0"
                            Background="{StaticResource BrandPurpleBrush}"
                            Foreground="#FFFFFF"
                            BorderThickness="0"
                            CornerRadius="8" Padding="16,8"/>
                </StackPanel>

                <!-- Grid View -->
                <Border x:Name="GridBorder" Padding="24,0,24,24">
                    <ItemsRepeater x:Name="GridRepeater">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout x:Name="GridLayout"
                                               MinItemWidth="150" MinItemHeight="280"
                                               MinColumnSpacing="12" MinRowSpacing="12"
                                               ItemsStretch="Fill"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:MovieListItem">
                                <local:MovieCardControl Movie="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Border>

                <!-- List View -->
                <Border x:Name="ListBorder" Padding="24,0,24,24" Visibility="Collapsed">
                    <ItemsRepeater x:Name="ListRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:MovieListItem">
                                <local:MovieRowControl Movie="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Border>
            </Grid>
          </StackPanel>
        </ScrollViewer>

        <!-- Loading indicator -->
        <ProgressRing x:Name="LoadingRing"
                      Grid.Row="2"
                      Width="40" Height="40"
                      Foreground="{StaticResource BrandPurpleBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Bottom"
                      Margin="0,0,0,20"
                      IsActive="False" Visibility="Collapsed"/>

        <!-- ═══ MULTI-SELECT BOTTOM ACTION BAR (v2.5) ═══ -->
        <!-- Appears the moment ≥1 cards are selected. Floats centered above
             the bottom edge so it never blocks scrolling/clicking. -->
        <Border x:Name="SelectionBar" Grid.Row="2"
                Visibility="Collapsed"
                VerticalAlignment="Bottom" HorizontalAlignment="Center"
                Margin="0,0,0,18" Padding="14,8"
                Background="{ThemeResource CardBrush}"
                BorderBrush="{StaticResource BrandPurpleBrush}"
                BorderThickness="1" CornerRadius="22">
            <!-- v2.6 — slides up from below when selection becomes non-empty -->
            <Border.RenderTransform>
                <TranslateTransform x:Name="SelectionBarSlide" Y="40"/>
            </Border.RenderTransform>
            <Border.Shadow>
                <ThemeShadow/>
            </Border.Shadow>
            <Border.Translation>0,0,32</Border.Translation>
            <StackPanel Orientation="Horizontal" Spacing="10" VerticalAlignment="Center">
                <TextBlock x:Name="SelectionCountText"
                           Foreground="{ThemeResource TextBrush}"
                           FontWeight="SemiBold" FontSize="13"
                           VerticalAlignment="Center" Margin="4,0,4,0"/>
                <Button x:Name="SelAddToListBtn" Content="📑 Add to list ▾"
                        Background="{StaticResource BrandPurpleBrush}"
                        Foreground="White" BorderThickness="0"
                        CornerRadius="8" Padding="12,6" FontSize="12">
                    <Button.Flyout>
                        <MenuFlyout x:Name="SelListsFlyout" Placement="Top"
                                    Opening="OnSelListsFlyoutOpening"/>
                    </Button.Flyout>
                </Button>
                <Button x:Name="SelWatchedBtn" Click="OnSelToggleWatched"
                        Content="✓ Watched"
                        Background="{ThemeResource CardBrush}"
                        Foreground="{ThemeResource TextBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        CornerRadius="8" Padding="10,6" FontSize="12"/>
                <Button x:Name="SelWatchlistBtn" Click="OnSelToggleWatchlist"
                        Content="📌 Watchlist"
                        Background="{ThemeResource CardBrush}"
                        Foreground="{ThemeResource TextBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        CornerRadius="8" Padding="10,6" FontSize="12"/>
                <Button x:Name="SelFavBtn" Click="OnSelToggleFav"
                        Content="★ Favorite"
                        Background="{ThemeResource CardBrush}"
                        Foreground="{ThemeResource TextBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        CornerRadius="8" Padding="10,6" FontSize="12"/>
                <Button x:Name="SelArchiveBtn" Click="OnSelArchive"
                        Background="{ThemeResource CardBrush}"
                        Foreground="{ThemeResource TextBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        CornerRadius="8" Padding="10,6" FontSize="12"
                        AutomationProperties.Name="Send to Watched and Gone"
                        ToolTipService.ToolTip="Keep as a record, remove from library">
                    <StackPanel Orientation="Horizontal" Spacing="6">
                        <FontIcon Glyph="&#xE7B8;" FontSize="12"
                                  FontFamily="Segoe Fluent Icons,Segoe MDL2 Assets"/>
                        <TextBlock Text="Watched &amp; Gone" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
                <Button x:Name="SelRemoveFromListBtn" Click="OnSelRemoveFromCurrentList"
                        Content="🗑 Remove from list"
                        Visibility="Collapsed"
                        Background="{ThemeResource CardBrush}"
                        Foreground="{ThemeResource TextBrush}"
                        BorderBrush="{ThemeResource BorderBrush}"
                        CornerRadius="8" Padding="10,6" FontSize="12"/>
                <Button Click="OnSelClear" Content="✕"
                        Background="Transparent"
                        Foreground="{ThemeResource MutedBrush}"
                        BorderThickness="0" CornerRadius="8" Padding="8,6" FontSize="12"
                        ToolTipService.ToolTip="Clear selection (Esc)"/>
            </StackPanel>
        </Border>
    </Grid>
</Page>
