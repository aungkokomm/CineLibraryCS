<Page
    x:Class="CineLibraryCS.Views.LibraryPage"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:local="using:CineLibraryCS.Views"
    xmlns:models="using:CineLibraryCS.Models"
    Background="{ThemeResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <!-- ═══ TOP BAR ═══ -->
        <Grid Grid.Row="0" Padding="24,16,24,0">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>

            <!-- Back/Toggle button (shows when sidebar is hidden) -->
            <Button x:Name="BackToggleBtn"
                    Grid.Column="0"
                    Click="OnBackToggleClick"
                    Background="{ThemeResource InputBgBrush}"
                    BorderBrush="{ThemeResource InputBorderBrush}"
                    BorderThickness="1"
                    CornerRadius="8"
                    Padding="8"
                    Width="36"
                    Height="36"
                    VerticalAlignment="Center"
                    Margin="0,0,12,0"
                    ToolTipService.ToolTip="Show sidebar"
                    Visibility="Collapsed">
                <TextBlock Text="‹" FontSize="18" FontWeight="Bold" 
                           VerticalAlignment="Center" HorizontalAlignment="Center"
                           Foreground="{ThemeResource TextBrush}"/>
            </Button>

            <TextBlock x:Name="PageTitleText" Grid.Column="1" Text="ALL MOVIES"
                       FontSize="18" FontWeight="Bold" Foreground="{ThemeResource TextBrush}"
                       CharacterSpacing="100" VerticalAlignment="Center"/>

            <AutoSuggestBox Grid.Column="2"
                            x:Name="SearchBox"
                            PlaceholderText="Search title, actor, director, plot…"
                            Margin="20,0"
                            QueryIcon="Find"
                            TextChanged="OnSearchChanged"
                            Background="{ThemeResource InputBgBrush}"
                            BorderBrush="{ThemeResource InputBorderBrush}"
                            Foreground="{ThemeResource TextBrush}"/>

            <StackPanel Grid.Column="3" Orientation="Horizontal" Spacing="12" VerticalAlignment="Center">

                <ComboBox x:Name="SortCombo"
                          SelectionChanged="OnSortChanged"
                          Background="{ThemeResource InputBgBrush}"
                          Foreground="{ThemeResource TextBrush}"
                          BorderBrush="{ThemeResource InputBorderBrush}"
                          MinWidth="140"
                          Height="36"
                          VerticalAlignment="Center">
                    <ComboBoxItem Tag="title:asc"      Content="Title ↑"/>
                    <ComboBoxItem Tag="title:desc"     Content="Title ↓"/>
                    <ComboBoxItem Tag="year:desc"      Content="Year ↓"/>
                    <ComboBoxItem Tag="year:asc"       Content="Year ↑"/>
                    <ComboBoxItem Tag="rating:desc"    Content="Rating ↓"/>
                    <ComboBoxItem Tag="rating:asc"     Content="Rating ↑"/>
                    <ComboBoxItem Tag="runtime:desc"   Content="Runtime ↓"/>
                    <ComboBoxItem Tag="runtime:asc"    Content="Runtime ↑"/>
                    <ComboBoxItem Tag="date_added:desc" Content="Date Added ↓"/>
                    <ComboBoxItem Tag="date_added:asc"  Content="Date Added ↑"/>
                </ComboBox>

                <SplitButton Content="Export" Click="OnExportCsvDefault"
                             Background="{ThemeResource InputBgBrush}"
                             Foreground="{ThemeResource TextBrush}"
                             BorderBrush="{ThemeResource InputBorderBrush}"
                             Padding="16,8"
                             Height="36"
                             VerticalAlignment="Center">
                    <SplitButton.Flyout>
                        <MenuFlyout Placement="Bottom">
                            <MenuFlyoutItem Text="Export as CSV"  Click="OnExportCsv"/>
                            <MenuFlyoutItem Text="Export as HTML" Click="OnExportHtml"/>
                        </MenuFlyout>
                    </SplitButton.Flyout>
                </SplitButton>

                <ToggleButton x:Name="GridViewToggle" IsChecked="True"
                              Click="OnViewGrid"
                              Background="{ThemeResource InputBgBrush}"
                              BorderBrush="{ThemeResource InputBorderBrush}"
                              Padding="10,8"
                              Height="36"
                              Width="36"
                              VerticalAlignment="Center"
                              ToolTipService.ToolTip="Grid view">
                    <TextBlock Text="⊞" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </ToggleButton>
                <ToggleButton x:Name="ListViewToggle"
                              Click="OnViewList"
                              Background="{ThemeResource InputBgBrush}"
                              BorderBrush="{ThemeResource InputBorderBrush}"
                              Padding="10,8"
                              Height="36"
                              Width="36"
                              VerticalAlignment="Center"
                              ToolTipService.ToolTip="List view">
                    <TextBlock Text="☰" FontSize="16" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                </ToggleButton>

                <!-- Density picker: S / M / L / XL (like Windows Explorer) -->
                <Border Background="{ThemeResource InputBgBrush}"
                        BorderBrush="{ThemeResource InputBorderBrush}"
                        BorderThickness="1" CornerRadius="4"
                        Height="36"
                        VerticalAlignment="Center">
                    <StackPanel Orientation="Horizontal">
                        <ToggleButton x:Name="DensityS" Click="OnDensityClick" Tag="S"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center"
                                      ToolTipService.ToolTip="Small (120px)">
                            <TextBlock Text="S" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                        <ToggleButton x:Name="DensityM" Click="OnDensityClick" Tag="M" IsChecked="True"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center"
                                      ToolTipService.ToolTip="Medium (150px)">
                            <TextBlock Text="M" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                        <ToggleButton x:Name="DensityL" Click="OnDensityClick" Tag="L"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center"
                                      ToolTipService.ToolTip="Large (190px)">
                            <TextBlock Text="L" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                        <ToggleButton x:Name="DensityXL" Click="OnDensityClick" Tag="XL"
                                      Background="Transparent" BorderThickness="0"
                                      Padding="12,8" Height="36" Width="36"
                                      VerticalAlignment="Center"
                                      ToolTipService.ToolTip="Extra large (240px)">
                            <TextBlock Text="XL" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" HorizontalAlignment="Center"/>
                        </ToggleButton>
                    </StackPanel>
                </Border>
            </StackPanel>
        </Grid>

        <!-- ═══ FILTER BAR ═══ -->
        <StackPanel Grid.Row="1" Orientation="Horizontal" Spacing="8" Padding="24,12,24,8">
            <TextBlock x:Name="MovieCountText" Text="0 movies"
                       Foreground="{ThemeResource MutedBrush}" FontSize="13"
                       VerticalAlignment="Center" Margin="0,0,12,0"/>
            <Button x:Name="FilterAll"      Content="All"       Tag="all"
                    Style="{StaticResource PillButtonActiveStyle}" Click="OnWatchedFilter"/>
            <Button x:Name="FilterUnwatched" Content="Unwatched" Tag="unwatched"
                    Style="{StaticResource PillButtonStyle}"       Click="OnWatchedFilter"/>
            <Button x:Name="FilterWatched"  Content="Watched"   Tag="watched"
                    Style="{StaticResource PillButtonStyle}"       Click="OnWatchedFilter"/>
        </StackPanel>

        <!-- ═══ MOVIE GRID / LIST ═══ -->
        <ScrollViewer Grid.Row="2" x:Name="MainScroller"
                      VerticalScrollBarVisibility="Auto"
                      ViewChanged="OnScrollChanged">
            <Grid>
                <!-- Empty state -->
                <StackPanel x:Name="EmptyState" Visibility="Collapsed"
                            VerticalAlignment="Center" HorizontalAlignment="Center"
                            Spacing="8" Margin="24,80,24,24">
                    <TextBlock Text="🎬" FontSize="48" HorizontalAlignment="Center" Opacity="0.5"/>
                    <TextBlock Text="No movies match your filters"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{ThemeResource TextBrush}"
                               HorizontalAlignment="Center"/>
                    <TextBlock x:Name="EmptyStateHint"
                               Text="Try clearing the search or choosing 'All' watched filter."
                               FontSize="12" Foreground="{ThemeResource MutedBrush}"
                               HorizontalAlignment="Center" TextAlignment="Center"/>
                </StackPanel>

                <!-- Grid View -->
                <Border x:Name="GridBorder" Padding="24,0,24,24">
                    <ItemsRepeater x:Name="GridRepeater">
                        <ItemsRepeater.Layout>
                            <UniformGridLayout x:Name="GridLayout"
                                               MinItemWidth="150" MinItemHeight="280"
                                               MinColumnSpacing="12" MinRowSpacing="12"
                                               ItemsStretch="None"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:MovieListItem">
                                <local:MovieCardControl Movie="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Border>

                <!-- List View -->
                <Border x:Name="ListBorder" Padding="24,0,24,24" Visibility="Collapsed">
                    <ItemsRepeater x:Name="ListRepeater">
                        <ItemsRepeater.Layout>
                            <StackLayout Orientation="Vertical" Spacing="2"/>
                        </ItemsRepeater.Layout>
                        <ItemsRepeater.ItemTemplate>
                            <DataTemplate x:DataType="models:MovieListItem">
                                <local:MovieRowControl Movie="{x:Bind}"/>
                            </DataTemplate>
                        </ItemsRepeater.ItemTemplate>
                    </ItemsRepeater>
                </Border>
            </Grid>
        </ScrollViewer>

        <!-- Loading indicator -->
        <ProgressRing x:Name="LoadingRing"
                      Grid.Row="2"
                      Width="40" Height="40"
                      Foreground="{StaticResource BrandPurpleBrush}"
                      HorizontalAlignment="Center" VerticalAlignment="Bottom"
                      Margin="0,0,0,20"
                      IsActive="False" Visibility="Collapsed"/>
    </Grid>
</Page>
